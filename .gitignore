## Ignore Visual Studio / MSBuild build output
[Bb]in/
[Oo]bj/
[Log]/

## Ignore Visual Studio cache and user files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

## Ignore VS Code settings and workspace configurations
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

## Ignore OS-specific files
.DS_Store
Thumbs.db

## Ignore Rider/Resharper files
.idea/
*.sln.iml

## Ignore publishing/deployment output
publish/
*.publishproj
*.pubxml
*.pubxml.user

## Ignore local environment settings and secrets
appsettings.local.json
*.secrets.json
.env
.env.*
!.env.example

## Ignore npm / Frontend dependencies (if any are added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
