@page
@model IndexModel
@{
    ViewData["Title"] = "Điều Phối Lịch Trình";
}

<style>
    /* Dashboard Container */
    .dashboard-container {
        display: flex;
        flex-direction: column;
        gap: 24px;
        padding-bottom: 40px;
    }

    /* Welcome Header */
    .welcome-section {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #ffffff;
        border-radius: 16px;
        padding: 24px 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 10px 15px -3px rgba(15,23,42,0.1);
        position: relative;
        overflow: hidden;
    }
    .welcome-section::after {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.03);
        border-radius: 50%;
        top: -100px;
        right: -100px;
        pointer-events: none;
    }
    .welcome-text h1 {
        font-size: 1.6rem;
        font-weight: 800;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .welcome-text p {
        font-size: 0.92rem;
        opacity: 0.8;
    }
    .current-time {
        text-align: right;
    }
    .current-time .time {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 2px;
        font-family: monospace;
    }
    .current-time .date {
        font-size: 0.82rem;
        opacity: 0.75;
    }

    /* KPI Grid */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }
    @@media (max-width: 1024px) {
        .kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @@media (max-width: 640px) {
        .kpi-grid {
            grid-template-columns: 1fr;
        }
    }

    /* KPI Cards */
    .kpi-card {
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }
    .kpi-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
    }
    .kpi-icon-wrap {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: #ffffff;
        flex-shrink: 0;
    }
    .kpi-blue { background: linear-gradient(135deg, #2563eb, #3b82f6); }
    .kpi-green { background: linear-gradient(135deg, #10b981, #34d399); }
    .kpi-red { background: linear-gradient(135deg, #ef4444, #f87171); }
    .kpi-purple { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }

    .kpi-info {
        flex: 1;
    }
    .kpi-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 2px;
    }
    .kpi-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0f172a;
    }

    /* Filter & Tab Bar */
    .filter-card {
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
    }
    .search-input-wrap {
        position: relative;
        margin-bottom: 16px;
    }
    .search-input-wrap i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
    }
    .search-input {
        width: 100%;
        padding: 12px 14px 12px 40px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .search-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
    }

    /* Tab Switch */
    .tab-row {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 4px;
    }
    .tab-btn {
        padding: 10px 18px;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        background: #f8fafc;
        color: #475569;
        border: 1px solid #e2e8f0;
        white-space: nowrap;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .tab-btn:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
    }
    .tab-btn.active {
        background: #0f172a;
        color: #ffffff;
        border-color: #0f172a;
    }
    .badge-count {
        background: rgba(0,0,0,0.1);
        color: inherit;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 20px;
    }
    .tab-btn.active .badge-count {
        background: rgba(255,255,255,0.2);
    }

    /* Schedule Grid & Cards */
    .schedule-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
    @@media (max-width: 768px) {
        .schedule-list {
            grid-template-columns: 1fr;
        }
    }

    .order-card {
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 18px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .order-card:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 12px -3px rgba(0,0,0,0.04);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed #f1f5f9;
        padding-bottom: 10px;
    }
    .order-code-link {
        font-family: monospace;
        font-weight: 800;
        color: #1e40af;
        text-decoration: none;
        background: #eff6ff;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.9rem;
        transition: color 0.15s;
    }
    .order-code-link:hover {
        color: #2563eb;
    }
    .order-code-plain {
        font-family: monospace;
        font-weight: 800;
        color: #475569;
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.9rem;
    }

    /* Status Badges */
    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .status-draft { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
    .status-rented { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
    .status-overdue { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }

    /* Customer details */
    .customer-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 0.9rem;
    }
    .info-line {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #334155;
    }
    .info-line i {
        color: #64748b;
        width: 16px;
    }

    /* Products lists */
    .items-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 4px;
    }
    .item-badge {
        font-size: 0.78rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 4px 8px;
        border-radius: 6px;
        color: #475569;
        font-weight: 500;
    }

    /* Card Footer Actions */
    .card-footer {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        border-top: 1px solid #f1f5f9;
        padding-top: 12px;
        margin-top: 4px;
    }
    .btn-action {
        background: #0f172a;
        color: #ffffff;
        padding: 8px 14px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.8rem;
        text-decoration: none;
        transition: background 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-action:hover {
        background: #1e293b;
    }
    .login-required-badge {
        font-size: 0.78rem;
        color: #94a3b8;
        font-style: italic;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        grid-column: span 2;
        padding: 60px 20px;
        color: #94a3b8;
        background: #ffffff;
        border-radius: 12px;
        border: 1px dashed #cbd5e1;
    }
    .empty-state i {
        font-size: 2.5rem;
        margin-bottom: 12px;
        color: #e2e8f0;
    }
    .empty-state p {
        font-size: 0.92rem;
    }
</style>

<div class="dashboard-container">
    
    <!-- Welcome Header -->
    <div class="welcome-section">
        <div class="welcome-text">
            <h1><i class="fas fa-truck-loading"></i> Hệ thống Điều phối & Bàn giao</h1>
            <p>Trực quan hóa lịch trình giao nhận trang phục của toàn bộ cửa hàng.</p>
        </div>
        <div class="current-time">
            <div class="time" id="liveTime">00:00:00</div>
            <div class="date" id="liveDate">Đang tải ngày...</div>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="kpi-grid">
        <div class="kpi-card" onclick="switchTab('handover')">
            <div class="kpi-icon-wrap kpi-blue">
                <i class="fas fa-truck"></i>
            </div>
            <div class="kpi-info">
                <div class="kpi-label">Chờ bàn giao hôm nay</div>
                <div class="kpi-value">@Model.HandoverToday.Count</div>
            </div>
        </div>

        <div class="kpi-card" onclick="switchTab('return')">
            <div class="kpi-icon-wrap kpi-green">
                <i class="fas fa-undo-alt"></i>
            </div>
            <div class="kpi-info">
                <div class="kpi-label">Chờ nhận trả hôm nay</div>
                <div class="kpi-value">@Model.ReturnToday.Count</div>
            </div>
        </div>

        <div class="kpi-card" onclick="switchTab('overdue')">
            <div class="kpi-icon-wrap kpi-red">
                <i class="fas fa-exclamation-circle"></i>
            </div>
            <div class="kpi-info">
                <div class="kpi-label">Quá hạn chưa trả</div>
                <div class="kpi-value">@Model.OverdueRentals.Count</div>
            </div>
        </div>

        <div class="kpi-card" onclick="switchTab('upcoming')">
            <div class="kpi-icon-wrap kpi-purple">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="kpi-info">
                <div class="kpi-label">Lịch 7 ngày tới</div>
                <div class="kpi-value">@Model.Next7DaysSchedule.Count</div>
            </div>
        </div>
    </div>

    <!-- Filters and Tabs -->
    <div class="filter-card">
        <div class="search-input-wrap">
            <i class="fas fa-search"></i>
            <input type="text" class="search-input" id="searchCoordination" placeholder="Tìm nhanh theo Mã đơn, Tên, SĐT khách hàng hoặc Tên/Mã sản phẩm..." oninput="filterOrders()" />
        </div>

        <div class="tab-row">
            <button class="tab-btn active" id="tab-handover" onclick="switchTab('handover')">
                🚚 Chờ bàn giao <span class="badge-count">@Model.HandoverToday.Count</span>
            </button>
            <button class="tab-btn" id="tab-return" onclick="switchTab('return')">
                🔄 Chờ nhận trả <span class="badge-count">@Model.ReturnToday.Count</span>
            </button>
            <button class="tab-btn" id="tab-overdue" onclick="switchTab('overdue')">
                ⚠️ Quá hạn trả <span class="badge-count">@Model.OverdueRentals.Count</span>
            </button>
            <button class="tab-btn" id="tab-upcoming" onclick="switchTab('upcoming')">
                📅 Lịch 7 ngày tới <span class="badge-count">@Model.Next7DaysSchedule.Count</span>
            </button>
        </div>
    </div>

    <!-- Lists Panels -->
    <!-- 1. Handover Today Panel -->
    <div class="panel-coordination" id="panel-handover">
        <div class="schedule-list">
            @if (Model.HandoverToday.Any())
            {
                foreach (var order in Model.HandoverToday)
                {
                    <div class="order-card" data-search="@order.Code.ToLower() @(order.Customer?.FullName.ToLower() ?? "") @(order.Customer?.PhoneNumber ?? "") @string.Join(" ", order.OrderDetails.Select(d => d.Product?.Code.ToLower() + " " + d.Product?.Name.ToLower()))">
                        <div class="card-header">
                            <a href="/Orders/Detail?id=@order.Id" class="order-code-link">@order.Code</a>
                            <span class="status-badge status-draft">Chờ lấy đồ</span>
                        </div>
                        <div class="customer-info">
                            <div class="info-line">
                                <i class="fas fa-user"></i>
                                <strong>@(order.Customer?.FullName ?? "Khách vãng lai")</strong>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-phone"></i>
                                <span>@(order.Customer?.PhoneNumber ?? "—")</span>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-calendar-day"></i>
                                <span style="color:#2563eb; font-weight: 600;">Hẹn lấy: @order.RentDate.AddHours(7).ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="items-wrap">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <span class="item-badge">
                                    📦 @detail.Product?.Code — @detail.Product?.Name @(!string.IsNullOrEmpty(detail.Product?.Size) ? $"({detail.Product.Size})" : "")
                                </span>
                            }
                        </div>
                        <div class="card-footer">
                            <a href="/Orders/Detail?id=@order.Id" class="btn-action">
                                <i class="fas fa-arrow-right"></i> Bàn giao & Xác nhận
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-check-circle" style="color: #10b981;"></i>
                    <p>Hôm nay không có đơn hàng nào chờ bàn giao.</p>
                </div>
            }
        </div>
    </div>

    <!-- 2. Return Today Panel -->
    <div class="panel-coordination" id="panel-return" style="display: none;">
        <div class="schedule-list">
            @if (Model.ReturnToday.Any())
            {
                foreach (var order in Model.ReturnToday)
                {
                    <div class="order-card" data-search="@order.Code.ToLower() @(order.Customer?.FullName.ToLower() ?? "") @(order.Customer?.PhoneNumber ?? "") @string.Join(" ", order.OrderDetails.Select(d => d.Product?.Code.ToLower() + " " + d.Product?.Name.ToLower()))">
                        <div class="card-header">
                            <a href="/Orders/Detail?id=@order.Id" class="order-code-link">@order.Code</a>
                            <span class="status-badge status-rented">Đang thuê</span>
                        </div>
                        <div class="customer-info">
                            <div class="info-line">
                                <i class="fas fa-user"></i>
                                <strong>@(order.Customer?.FullName ?? "Khách vãng lai")</strong>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-phone"></i>
                                <span>@(order.Customer?.PhoneNumber ?? "—")</span>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-calendar-check"></i>
                                <span style="color:#10b981; font-weight: 600;">Hạn trả: @order.DueDate.AddHours(7).ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="items-wrap">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <span class="item-badge">
                                    📦 @detail.Product?.Code — @detail.Product?.Name @(!string.IsNullOrEmpty(detail.Product?.Size) ? $"({detail.Product.Size})" : "")
                                </span>
                            }
                        </div>
                        <div class="card-footer">
                            <a href="/Orders/Detail?id=@order.Id" class="btn-action">
                                <i class="fas fa-undo"></i> Nhận trả & Quyết toán
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-check" style="color: #64748b;"></i>
                    <p>Hôm nay không có lịch trả đồ nào.</p>
                </div>
            }
        </div>
    </div>

    <!-- 3. Overdue Panel -->
    <div class="panel-coordination" id="panel-overdue" style="display: none;">
        <div class="schedule-list">
            @if (Model.OverdueRentals.Any())
            {
                foreach (var order in Model.OverdueRentals)
                {
                    <div class="order-card" data-search="@order.Code.ToLower() @(order.Customer?.FullName.ToLower() ?? "") @(order.Customer?.PhoneNumber ?? "") @string.Join(" ", order.OrderDetails.Select(d => d.Product?.Code.ToLower() + " " + d.Product?.Name.ToLower()))" style="border-color: #fca5a5;">
                        <div class="card-header">
                            <a href="/Orders/Detail?id=@order.Id" class="order-code-link" style="color: #991b1b; background: #fef2f2;">@order.Code</a>
                            <span class="status-badge status-overdue">Quá hạn</span>
                        </div>
                        <div class="customer-info">
                            <div class="info-line">
                                <i class="fas fa-user"></i>
                                <strong>@(order.Customer?.FullName ?? "Khách vãng lai")</strong>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-phone"></i>
                                <span>@(order.Customer?.PhoneNumber ?? "—")</span>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-exclamation-triangle" style="color:#ef4444;"></i>
                                <span style="color:#ef4444; font-weight: 700;">Hạn cũ: @order.DueDate.AddHours(7).ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="items-wrap">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <span class="item-badge" style="background:#fff5f5; border-color:#feb2b2;">
                                    📦 @detail.Product?.Code — @detail.Product?.Name
                                </span>
                            }
                        </div>
                        <div class="card-footer">
                            <a href="/Orders/Detail?id=@order.Id" class="btn-action" style="background:#dc2626;">
                                <i class="fas fa-phone-alt"></i> Xử lý quá hạn
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-thumbs-up" style="color: #10b981;"></i>
                    <p>Tuyệt vời! Không có đơn thuê nào bị quá hạn.</p>
                </div>
            }
        </div>
    </div>

    <!-- 4. Upcoming Panel -->
    <div class="panel-coordination" id="panel-upcoming" style="display: none;">
        <div class="schedule-list">
            @if (Model.Next7DaysSchedule.Any())
            {
                foreach (var order in Model.Next7DaysSchedule)
                {
                    var isHandover = order.Status == "Draft";
                    var badgeStyle = isHandover ? "status-draft" : "status-rented";
                    var dateLabel = isHandover ? "Hẹn lấy" : "Hạn trả";
                    var labelColor = isHandover ? "#2563eb" : "#10b981";
                    
                    <div class="order-card" data-search="@order.Code.ToLower() @(order.Customer?.FullName.ToLower() ?? "") @(order.Customer?.PhoneNumber ?? "") @string.Join(" ", order.OrderDetails.Select(d => d.Product?.Code.ToLower() + " " + d.Product?.Name.ToLower()))">
                        <div class="card-header">
                            <a href="/Orders/Detail?id=@order.Id" class="order-code-link">@order.Code</a>
                            <span class="status-badge @badgeStyle">@(isHandover ? "Chờ lấy" : "Đang thuê")</span>
                        </div>
                        <div class="customer-info">
                            <div class="info-line">
                                <i class="fas fa-user"></i>
                                <strong>@(order.Customer?.FullName ?? "Khách vãng lai")</strong>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-phone"></i>
                                <span>@(order.Customer?.PhoneNumber ?? "—")</span>
                            </div>
                            <div class="info-line">
                                <i class="fas fa-calendar-alt"></i>
                                <span style="color:@labelColor; font-weight: 600;">
                                    @dateLabel: @(isHandover ? order.RentDate.AddHours(7).ToString("dd/MM/yyyy") : order.DueDate.AddHours(7).ToString("dd/MM/yyyy"))
                                </span>
                            </div>
                        </div>
                        <div class="items-wrap">
                            @foreach (var detail in order.OrderDetails)
                            {
                                <span class="item-badge">
                                    📦 @detail.Product?.Code — @detail.Product?.Name
                                </span>
                            }
                        </div>
                        <div class="card-footer">
                            <a href="/Orders/Detail?id=@order.Id" class="btn-action">
                                <i class="fas fa-eye"></i> Xem Chi Tiết
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-alt" style="color: #64748b;"></i>
                    <p>Không có lịch trình giao nhận nào trong 7 ngày tới.</p>
                </div>
            }
        </div>
    </div>

</div>

<script>
    // Live Time Clock
    function updateClock() {
        const now = new Date();
        const optionsDate = { weekday: 'long', year: 'numeric', month: '2-digit', day: '2-digit' };
        
        const timeStr = now.toLocaleTimeString('vi-VN', { hour12: false });
        const dateStr = now.toLocaleDateString('vi-VN', optionsDate);
        
        document.getElementById('liveTime').textContent = timeStr;
        document.getElementById('liveDate').textContent = dateStr;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // Tab switcher logic
    let currentTab = 'handover';
    function switchTab(tabId) {
        currentTab = tabId;
        
        // Update active class on tab buttons
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        document.getElementById('tab-' + tabId).classList.add('active');
        
        // Show selected panel, hide others
        document.querySelectorAll('.panel-coordination').forEach(panel => {
            panel.style.display = 'none';
        });
        document.getElementById('panel-' + tabId).style.display = 'block';

        // Reapply filter
        filterOrders();
    }

    // Live search filter logic
    function filterOrders() {
        const query = document.getElementById('searchCoordination').value.trim().toLowerCase();
        const currentPanel = document.getElementById('panel-' + currentTab);
        const cards = currentPanel.querySelectorAll('.order-card');
        const emptyState = currentPanel.querySelector('.empty-state');
        
        let visibleCount = 0;
        
        cards.forEach(card => {
            const searchText = card.getAttribute('data-search') || '';
            if (searchText.includes(query)) {
                card.style.display = 'flex';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Toggle empty state if search filters out everything
        if (cards.length > 0) {
            if (visibleCount === 0) {
                // If we don't have an ad-hoc empty search state, show a small text or reuse emptyState
                if (emptyState) {
                    emptyState.style.display = 'block';
                    emptyState.querySelector('p').textContent = 'Không tìm thấy kết quả phù hợp với từ khóa "' + query + '".';
                }
            } else {
                if (emptyState) emptyState.style.display = 'none';
            }
        }
    }
</script>
