@page
@model ClothingRentalUI.Pages.Products.PriceListsModel
@{
    ViewData["Title"] = "Quản lý loại giá";
}

<style>
    /* Card Layout */
    .data-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .card-title-group h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-title-group p {
        font-size: 0.88rem;
        color: #64748b;
    }

    .table-responsive {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 500px;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .custom-table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
    }

    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }

    .price-value {
        font-weight: 700;
        color: #059669; /* Emerald 600 */
    }
    
    .deposit-value {
        font-weight: 700;
        color: #d97706; /* Amber 600 */
    }

    /* Pagination */
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding: 10px 0;
    }
    
    .pagination-info {
        font-size: 0.9rem;
        color: #64748b;
    }

    .pagination-controls {
        display: flex;
        gap: 8px;
    }

    .btn-page {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        color: #334155;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-page:hover:not(.disabled) {
        background: #f8fafc;
        border-color: #94a3b8;
    }

    .btn-page.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background: #f1f5f9;
    }

    .btn-page.active {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    /* Badges */
    .badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-status-active {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .badge-status-locked {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    /* Buttons */
    .btn-primary-grad {
        background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
        color: #ffffff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
    }

    .btn-action-outline {
        border-radius: 8px;
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        font-size: 1rem;
        margin-right: 4px;
    }

    .btn-action-outline.edit { color: #2563eb; }
    .btn-action-outline.lock { color: #ea580c; }
    .btn-action-outline.unlock { color: #10b981; }
    .btn-action-outline.log { color: #64748b; }

    .btn-action-outline:hover { background: #f8fafc; border-color: #94a3b8; }

    /* Custom Modal */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background: #ffffff;
        border-radius: 16px;
        width: 100%;
        max-width: 550px;
        padding: 30px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .modal-overlay.active { display: flex; }
    .modal-overlay.active .modal-content { transform: translateY(0); }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .modal-header h3 { margin: 0; font-size: 1.25rem; font-weight: 700; color: #0f172a; }
    .btn-close { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #64748b; }

    /* Form inside modal */
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-size: 0.88rem; font-weight: 600; color: #475569; margin-bottom: 8px; }
    .form-input {
        width: 100%; padding: 11px 16px; border: 1px solid #cbd5e1; border-radius: 10px;
        font-family: inherit; font-size: 0.95rem; outline: none;
    }
    .form-input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
    
    .input-wrapper-currency {
        position: relative;
        display: flex;
        align-items: center;
    }
    .input-wrapper-currency .currency-suffix {
        position: absolute;
        right: 16px;
        color: #94a3b8;
        font-weight: 600;
        pointer-events: none;
    }
    
    .modal-footer { display: flex; justify-content: flex-end; gap: 12px; margin-top: 30px; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: none; padding: 10px 18px; border-radius: 10px; font-weight: 600; cursor: pointer; }

    /* Alert */
    .custom-alert {
        display: flex; align-items: center; gap: 12px; padding: 16px 20px; border-radius: 12px; margin-bottom: 24px; font-weight: 500;
    }
    .alert-success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .alert-danger { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }

    /* Search autocomplete */
    .search-wrap { position: relative; }
    .search-results { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid #cbd5e1; border-radius: 10px; max-height: 220px; overflow-y: auto; z-index: 1050; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); display: none; }
    .search-results.active { display: block; }
    .sr-item { padding: 10px 14px; cursor: pointer; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; transition: background 0.15s; text-align: left; }
    .sr-item:hover { background: #eff6ff; }
    .sr-item .sr-name { font-weight: 600; color: #0f172a; }
    .sr-item .sr-sub { font-size: 0.8rem; color: #64748b; margin-top: 2px; }
    
    /* Gift badges in modal */
    .gift-badge { display: inline-flex; align-items: center; gap: 6px; background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; padding: 4px 8px; border-radius: 6px; font-size: 0.82rem; font-weight: 600; }
    .gift-badge .btn-remove-gift { background: none; border: none; color: #ef4444; font-size: 0.9rem; cursor: pointer; padding: 0; display: inline-flex; align-items: center; }
    .gift-badge .btn-remove-gift:hover { color: #b91c1c; }
</style>


<div class="data-card">
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Danh sách Loại giá (PriceList)</h2>
            <p>Quản lý các loại giá cho thuê, quy định tiền cọc và lịch sử thay đổi giá.</p>
        </div>
        @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("PRICELIST_CREATE"))
        {
            <div>
                <button class="btn-primary-grad" onclick="openCreateModal()">
                    <span>➕</span> Thêm loại giá mới
                </button>
            </div>
        }
    </div>

    @if (Model.SuccessMessage != null)
    {
        <div class="custom-alert alert-success"><span>✔️</span> @Model.SuccessMessage</div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="custom-alert alert-danger"><span>⚠️</span> @Model.ErrorMessage</div>
    }

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">STT</th>
                    <th>Tên loại giá</th>
                    <th>Giá thuê/ngày</th>
                    <th>Tiền cọc</th>
                    <th>Quà tặng kèm</th>
                    <th>Ghi chú</th>
                    <th>Trạng thái</th>

                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int sttIndex = 1; }
                @foreach (var pl in Model.PriceLists)
                {
                    int stt = (Model.PageIndex - 1) * PriceListsModel.PageSize + sttIndex++;
                    <tr>
                        <td style="text-align: center; color: #64748b; font-weight: 600;">@stt</td>
                        <td style="font-weight: 600; color: #0f172a;">@pl.Name</td>
                        <td><span class="price-value">@pl.PricePerDay.ToString("N0") đ</span></td>
                        <td><span class="deposit-value">@pl.Deposit.ToString("N0") đ</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(pl.GiftProductsJson) && pl.GiftProductsJson != "[]")
                            {
                                try {
                                    var gifts = System.Text.Json.JsonSerializer.Deserialize<List<PriceListsModel.PriceListGiftItem>>(pl.GiftProductsJson) ?? new();
                                    if (gifts.Any()) {
                                        foreach (var g in gifts)
                                        {
                                            <div style="font-size:0.75rem; margin-bottom:4px; color:#1e40af; background:#eff6ff; padding:2px 6px; border-radius:4px; display:inline-block; border:1px solid #bfdbfe; margin-right:4px;">
                                                🎁 @g.Code - @g.Name @(string.IsNullOrEmpty(g.Size) ? "" : "(" + g.Size + ")") x @g.Quantity
                                            </div>
                                        }
                                    } else {
                                        <span style="color: #94a3b8; font-size: 0.85rem;">—</span>
                                    }
                                } catch {
                                    <span style="color: #dc2626; font-size: 0.85rem;">Lỗi dữ liệu</span>
                                }
                            }
                            else
                            {
                                <span style="color: #94a3b8; font-size: 0.85rem;">—</span>
                            }
                        </td>
                        <td><span style="color: #64748b; font-size: 0.85rem;">@(string.IsNullOrEmpty(pl.Description) ? "—" : pl.Description)</span></td>
                        <td>
                            @if (pl.IsActive)
                            {
                                <span class="badge badge-status-active">Đang áp dụng</span>
                            }
                            else
                            {
                                <span class="badge badge-status-locked">Ngừng áp dụng</span>
                            }
                        </td>
                        <td>
                            @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("PRICELIST_EDIT"))
                            {
                                <button class="btn-action-outline edit" 
                                        data-id="@pl.Id"
                                        data-name="@pl.Name"
                                        data-price="@pl.PricePerDay.ToString("G", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-deposit="@pl.Deposit.ToString("G", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-desc="@pl.Description"
                                        data-gifts="@pl.GiftProductsJson"
                                        onclick="openEditModalFromButton(this)" 
                                        title="Chỉnh sửa">
                                    ✏️
                                </button>
                            }

                            
                            @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("PRICELIST_LOCK"))
                            {
                                <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@pl.Id" style="display:inline;">
                                    @if (pl.IsActive)
                                    {
                                        <button type="submit" class="btn-action-outline lock" title="Tạm khóa">🔒</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn-action-outline unlock" title="Mở khóa">🔓</button>
                                    }
                                </form>
                            }

                            <button class="btn-action-outline log" onclick="viewLog(@pl.Id)" title="Xem Log">
                                📜
                            </button>
                            <!-- Hidden JSON payload for logs -->
                            <div id="logData-@pl.Id" style="display:none;">@pl.SystemLog</div>
                        </td>
                    </tr>
                }
                @if(!Model.PriceLists.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: #94a3b8; padding: 40px;">Chưa có dữ liệu loại giá.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị trang @Model.PageIndex / @Model.TotalPages (Tổng cộng @Model.TotalItems bản ghi)
            </div>
            <div class="pagination-controls">
                @if (Model.PageIndex > 1)
                {
                    <a href="?PageIndex=@(Model.PageIndex - 1)" class="btn-page">Trước</a>
                }
                else
                {
                    <span class="btn-page disabled">Trước</span>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageIndex)
                    {
                        <span class="btn-page active">@i</span>
                    }
                    else if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                    {
                        <a href="?PageIndex=@i" class="btn-page">@i</a>
                    }
                    else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                    {
                        <span class="btn-page disabled">...</span>
                    }
                }

                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?PageIndex=@(Model.PageIndex + 1)" class="btn-page">Sau</a>
                }
                else
                {
                    <span class="btn-page disabled">Sau</span>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Thêm/Sửa PriceList -->
<div id="priceListModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalTitle">Thêm loại giá mới</h3>
            <button class="btn-close" onclick="closeModal('priceListModal')">✕</button>
        </div>
        <form method="post" id="priceListForm">
            <input type="hidden" name="id" id="priceListId" />
            
            <div class="form-group">
                <label class="form-label" for="name">Tên loại giá</label>
                <input type="text" name="name" id="name" class="form-input" placeholder="VD: Áo dài phổ thông" required />
            </div>

            <div class="form-group">
                <label class="form-label" for="pricePerDayDisplay">Giá cho thuê (1 ngày)</label>
                <div class="input-wrapper-currency">
                    <input type="text" id="pricePerDayDisplay" class="form-input" placeholder="VD: 250,000" required oninput="formatCurrency(this, 'pricePerDay')" />
                    <input type="hidden" name="pricePerDay" id="pricePerDay" />
                    <span class="currency-suffix">VNĐ</span>
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label" for="depositDisplay">Tiền đặt cọc mặc định</label>
                <div class="input-wrapper-currency">
                    <input type="text" id="depositDisplay" class="form-input" placeholder="VD: 1,000,000" required oninput="formatCurrency(this, 'deposit')" />
                    <input type="hidden" name="deposit" id="deposit" />
                    <span class="currency-suffix">VNĐ</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="description">Mô tả thêm (Tùy chọn)</label>
                <input type="text" name="description" id="description" class="form-input" placeholder="Nhập ghi chú nếu có" />
            </div>

            <!-- Cấu hình quà tặng kèm -->
            <div class="form-group" style="border-top: 1px dashed #cbd5e1; padding-top: 16px;">
                <label class="form-label" style="display: flex; align-items: center; gap: 6px; font-weight: 600;">
                    🎁 Quà tặng kèm (chỉ áp dụng đơn thuê)
                </label>
                <div class="search-wrap" style="margin-bottom: 10px;">
                    <input type="text" id="giftProductSearch" class="form-input" placeholder="Tìm sản phẩm làm quà tặng..." oninput="searchGiftProducts(this.value)" autocomplete="off" />
                    <div id="giftProductResults" class="search-results" style="max-height: 180px;"></div>
                </div>
                <div id="giftItemsContainer" style="display: flex; flex-wrap: wrap; gap: 8px; min-height: 48px; padding: 10px; border: 1px dashed #cbd5e1; border-radius: 10px; background: #f8fafc; align-items: center;">
                    <span id="noGiftsText" style="font-size: 0.82rem; color: #94a3b8;">Chưa chọn quà tặng nào.</span>
                </div>
                <input type="hidden" name="giftProductsJson" id="giftProductsJsonInput" value="[]" />
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('priceListModal')">Hủy</button>
                <button type="submit" class="btn-primary-grad" id="btnSubmitForm">Lưu loại giá</button>
            </div>
        </form>
    </div>
</div>


<!-- Modal Xem Audit Log -->
<div id="logModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h3>Lịch sử thay đổi giá</h3>
            <button class="btn-close" onclick="closeModal('logModal')">✕</button>
        </div>
        <div id="logContainer" style="max-height: 400px; overflow-y: auto; font-size: 0.85rem;">
            <!-- Render logs dynamically via JS -->
        </div>
    </div>
</div>

<script>
    let selectedGifts = [];
    let giftSearchTimeout;

    function renderGifts() {
        const container = document.getElementById('giftItemsContainer');
        const noGiftsText = document.getElementById('noGiftsText');
        const hiddenInput = document.getElementById('giftProductsJsonInput');
        
        // Remove existing gift badges
        container.querySelectorAll('.gift-badge').forEach(el => el.remove());
        
        if (selectedGifts.length === 0) {
            noGiftsText.style.display = 'block';
            hiddenInput.value = '[]';
            return;
        }
        
        noGiftsText.style.display = 'none';
        
        selectedGifts.forEach((gift, idx) => {
            const badge = document.createElement('div');
            badge.className = 'gift-badge';
            badge.style.display = 'inline-flex';
            badge.style.alignItems = 'center';
            badge.style.gap = '6px';
            badge.innerHTML = `
                <span>🎁 ${gift.Code} - ${gift.Name} ${gift.Size ? '(' + gift.Size + ')' : ''}</span>
                <input type="number" class="gift-qty-input" style="width: 45px; height: 20px; font-size: 0.75rem; text-align: center; border: 1px solid #cbd5e1; border-radius: 4px; padding: 0 2px;" value="${gift.Quantity || 1}" min="1" onchange="updateGiftQty(${idx}, this.value)" />
                <button type="button" class="btn-remove-gift" onclick="removeGift(${idx})">✕</button>
            `;
            container.appendChild(badge);
        });
        
        // Format object for serialization matching PriceListGiftItem DTO
        const formattedGifts = selectedGifts.map(g => ({
            ProductId: g.ProductId,
            Code: g.Code,
            Name: g.Name,
            Size: g.Size || '',
            Color: g.Color || '',
            Quantity: parseInt(g.Quantity) || 1
        }));
        hiddenInput.value = JSON.stringify(formattedGifts);
    }

    function updateGiftQty(index, qty) {
        let val = parseInt(qty) || 1;
        if (val < 1) val = 1;
        selectedGifts[index].Quantity = val;
        renderGifts();
    }

    function removeGift(index) {
        selectedGifts.splice(index, 1);
        renderGifts();
    }

    function addGift(product) {
        // Prevent duplicate products in gifts
        if (selectedGifts.some(g => g.ProductId === product.id)) {
            alert('Sản phẩm này đã có trong danh sách quà tặng.');
            return;
        }
        
        selectedGifts.push({
            ProductId: product.id,
            Code: product.code,
            Name: product.name,
            Size: product.size || '',
            Color: product.color || '',
            Quantity: 1
        });
        
        document.getElementById('giftProductSearch').value = '';
        document.getElementById('giftProductResults').classList.remove('active');
        renderGifts();
    }

    async function searchGiftProducts(term) {
        clearTimeout(giftSearchTimeout);
        if (term.length < 1) {
            document.getElementById('giftProductResults').classList.remove('active');
            return;
        }
        
        giftSearchTimeout = setTimeout(async () => {
            try {
                const res = await fetch(`?handler=SearchProducts&term=${encodeURIComponent(term)}`);
                const data = await res.json();
                const el = document.getElementById('giftProductResults');
                
                if (data.success && data.data.length > 0) {
                    el.searchResults = data.data;
                    el.innerHTML = data.data.map((p, i) => `
                        <div class="sr-item" onclick="addGift(document.getElementById('giftProductResults').searchResults[${i}])">
                            <div class="sr-name">${p.code} — ${p.name}</div>
                            <div class="sr-sub">${p.size || ''} ${p.color || ''}</div>
                        </div>
                    `).join('');
                    el.classList.add('active');
                } else {
                    el.innerHTML = '<div class="sr-item" style="color:#64748b;">Không tìm thấy sản phẩm.</div>';
                    el.classList.add('active');
                }
            } catch (err) {
                console.error(err);
            }
        }, 250);
    }

    // Close gift search results on outside click
    document.addEventListener('click', e => {
        if (!e.target.closest('#giftProductSearch') && !e.target.closest('#giftProductResults')) {
            document.getElementById('giftProductResults').classList.remove('active');
        }
    });

    function openCreateModal() {
        document.getElementById('modalTitle').innerText = 'Thêm loại giá mới';
        document.getElementById('priceListForm').action = '?handler=Create';
        
        document.getElementById('priceListId').value = '';
        document.getElementById('name').value = '';
        
        document.getElementById('pricePerDay').value = '';
        document.getElementById('pricePerDayDisplay').value = '';
        
        document.getElementById('deposit').value = '';
        document.getElementById('depositDisplay').value = '';
        
        document.getElementById('description').value = '';
        
        // Reset gifts config
        selectedGifts = [];
        document.getElementById('giftProductSearch').value = '';
        renderGifts();

        document.getElementById('priceListModal').classList.add('active');
    }

    function openEditModalFromButton(btn) {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name') || '';
        const price = parseFloat(btn.getAttribute('data-price')) || 0;
        const deposit = parseFloat(btn.getAttribute('data-deposit')) || 0;
        const desc = btn.getAttribute('data-desc') || '';
        const giftsJson = btn.getAttribute('data-gifts') || '[]';
        
        openEditModal(id, name, price, deposit, desc, giftsJson);
    }

    function openEditModal(id, name, price, deposit, desc, giftsJson) {
        document.getElementById('modalTitle').innerText = 'Chỉnh sửa loại giá';
        document.getElementById('priceListForm').action = '?handler=Update';
        
        document.getElementById('priceListId').value = id;
        document.getElementById('name').value = name;
        
        document.getElementById('pricePerDay').value = price;
        document.getElementById('pricePerDayDisplay').value = price.toLocaleString('en-US');
        
        document.getElementById('deposit').value = deposit;
        document.getElementById('depositDisplay').value = deposit.toLocaleString('en-US');
        
        document.getElementById('description').value = desc;
        
        // Populate gifts config
        document.getElementById('giftProductSearch').value = '';
        try {
            selectedGifts = JSON.parse(giftsJson || '[]');
            selectedGifts.forEach(g => {
                if (!g.Quantity) g.Quantity = 1;
            });
        } catch(e) {
            selectedGifts = [];
        }
        renderGifts();

        document.getElementById('priceListModal').classList.add('active');
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('active');
    }

    function viewLog(id) {
        const logDataStr = document.getElementById('logData-' + id).innerText;
        const logContainer = document.getElementById('logContainer');
        logContainer.innerHTML = '';

        try {
            const logs = JSON.parse(logDataStr);
            if (logs.length === 0) {
                logContainer.innerHTML = '<p style="color:#94a3b8; text-align:center;">Chưa có lịch sử thao tác.</p>';
            } else {
                let html = '<ul style="list-style:none; padding:0; margin:0;">';
                // Đảo ngược mảng để log mới nhất lên đầu
                logs.reverse().forEach(log => {
                    const d = new Date(log.Timestamp);
                    html += `
                        <li style="border-bottom: 1px solid #e2e8f0; padding: 12px 0;">
                            <div style="color: #1d4ed8; font-weight: 600; margin-bottom: 4px;">
                                [${log.Action}] - ${log.Username}
                            </div>
                            <div style="color: #475569; margin-bottom: 4px;">${log.Details}</div>
                            <div style="color: #94a3b8; font-size: 0.75rem;">🕒 ${d.toLocaleString()}</div>
                        </li>
                    `;
                });
                html += '</ul>';
                logContainer.innerHTML = html;
            }
        } catch (e) {
            logContainer.innerHTML = '<p style="color:red;">Lỗi phân tích dữ liệu log.</p>';
        }

        document.getElementById('logModal').classList.add('active');
    }

    function formatCurrency(inputElem, hiddenId) {
        // Xóa tất cả các ký tự không phải số
        let val = inputElem.value.replace(/[^0-9]/g, '');
        if (val === '') {
            document.getElementById(hiddenId).value = '';
            inputElem.value = '';
            return;
        }
        // Lưu giá trị thực (chỉ có số) vào ô hidden để post lên server
        document.getElementById(hiddenId).value = val;
        // Hiển thị lại số đã format có dấu phẩy phân cách phần nghìn
        inputElem.value = parseInt(val, 10).toLocaleString('en-US');
    }
</script>
