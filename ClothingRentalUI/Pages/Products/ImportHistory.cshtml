@page
@model ClothingRentalUI.Pages.Products.ImportHistoryModel
@{
    ViewData["Title"] = "Lịch sử Nhập hàng";
}

<style>
    .data-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .card-title-group h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-title-group p {
        font-size: 0.88rem;
        color: #64748b;
    }
    
    .filter-container {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
        background: #f8fafc;
        padding: 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        align-items: center;
    }

    .form-control {
        padding: 10px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .btn-search {
        background-color: #0f172a;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-search:hover {
        background-color: #334155;
    }

    .table-responsive {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 600px;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .custom-table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
    }

    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }

    .code-prefix {
        font-weight: 700;
        color: #1d4ed8;
        background: #eff6ff;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: monospace;
        display: inline-block;
    }

    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }
    
    .pagination-info {
        font-size: 0.9rem;
        color: #64748b;
    }

    .pagination-controls {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .btn-page {
        padding: 8px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background: #ffffff;
        color: #334155;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.88rem;
        transition: all 0.2s;
        cursor: pointer;
        display: inline-block;
    }

    .btn-page:hover:not(.disabled) {
        background: #f1f5f9;
        border-color: #94a3b8;
    }

    .btn-page.active {
        background: #0f172a;
        color: #ffffff;
        border-color: #0f172a;
    }

    .btn-page.disabled {
        color: #94a3b8;
        background: #f8fafc;
        border-color: #e2e8f0;
        cursor: not-allowed;
    }
</style>

<div class="data-card">
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Lịch sử Nhập hàng</h2>
            <p>Kiểm tra số lượng hàng hóa đã nhập vào kho theo thời gian</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #fecaca;">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <!-- Bộ lọc -->
    <form method="get" class="filter-container">
        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 4px;">Từ ngày:</label>
            <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        
        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 4px;">Đến ngày:</label>
            <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        
        <div style="display: flex; align-items: flex-end; margin-bottom: 2px; gap: 8px;">
            <button type="submit" class="btn-search"><i class="fas fa-filter"></i> Lọc dữ liệu</button>
            <button type="submit" name="handler" value="ExportExcel" class="btn-search" style="background: #16a34a;"><i class="fas fa-file-excel"></i> Xuất Excel</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th>Thời gian</th>
                    <th style="width: 180px;">Sản phẩm</th>
                    <th>Tên Sản phẩm</th>
                    <th style="text-align: right;">Giá nhập</th>
                    <th style="text-align: center;">SL Nhập</th>
                    <th>Ghi chú</th>
                    <th>Người thực hiện</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Histories.Any())
                {
                    int startIndex = (Model.PageIndex - 1) * 25 + 1;
                    foreach (var item in Model.Histories)
                    {
                        <tr>
                            <td style="text-align: center; color: #64748b; font-weight: 500;">@startIndex</td>
                            <td>
                                <!-- Hiển thị ngày giờ theo chuẩn Việt Nam -->
                                @item.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                @if(item.Product != null)
                                {
                                    <span class="code-prefix">@item.Product.Code</span>
                                }
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #0f172a;">@(item.Product?.Name ?? "Sản phẩm đã bị xóa")</div>
                            </td>
                            <td style="text-align: right; color: #16a34a; font-weight: 600;">
                                @(item.Product != null ? item.Product.ImportPrice.ToString("N0") + " đ" : "-")
                            </td>
                            <td style="text-align: center;">
                                <span style="font-weight: 700; color: #1d4ed8; background: #eff6ff; padding: 4px 12px; border-radius: 20px;">
                                    +@item.QuantityChange
                                </span>
                            </td>
                            <td>
                                <span style="font-size: 0.9rem; color: #475569;">@item.Note</span>
                            </td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 6px; font-size: 0.9rem; color: #334155;">
                                    <i class="fas fa-user-circle" style="color: #94a3b8;"></i> @item.PerformedBy
                                </div>
                            </td>
                        </tr>
                        startIndex++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="text-align: center; padding: 40px; color: #64748b;">
                            <i class="fas fa-clipboard-list fa-3x" style="color: #cbd5e1; margin-bottom: 12px;"></i>
                            <p>Không có dữ liệu nhập kho trong khoảng thời gian này.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị trang @Model.PageIndex / @Model.TotalPages (Tổng @Model.TotalItems bản ghi)
            </div>
            <div class="pagination-controls">
                @if (Model.PageIndex > 1)
                {
                    <a href="?pageIndex=@(Model.PageIndex - 1)&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page">Trước</a>
                }
                else
                {
                    <span class="btn-page disabled">Trước</span>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.PageIndex) <= 2)
                    {
                        <a href="?pageIndex=@i&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page @(i == Model.PageIndex ? "active" : "")">@i</a>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <span style="padding: 8px;">...</span>
                    }
                }
                
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?pageIndex=@(Model.PageIndex + 1)&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page">Sau</a>
                }
                else
                {
                    <span class="btn-page disabled">Sau</span>
                }
            </div>
        </div>
    }
</div>
