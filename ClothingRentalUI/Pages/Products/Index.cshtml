        <!-- Loading Progress -->
        <div id="importProgressContainer" style="text-align: center; padding: 20px 0; display: none;">
            <div class="spinner" style="border: 4px solid #f3f3f3; border-top: 4px solid #16a34a; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 12px auto;"></div>
            <p style="font-weight: 600; color: #1e293b; margin: 0;">Đang xử lý tệp tin và import dữ liệu...</p>
            <p style="font-size: 0.85rem; color: #64748b; margin-top: 4px;">Vui lòng không đóng trình duyệt hoặc tải lại trang.</p>
        </div>
        
        <!-- Kết quả Import -->
        <div id="importResultContainer" style="display: none; text-align: left;">
            <div style="background: #eff6ff; border: 1px solid #bfdbfe; padding: 16px; border-radius: 12px; margin-bottom: 20px; display: flex; justify-content: space-around; text-align: center;">
                <div>
                    <div id="resultCatsCount" style="font-size: 1.8rem; font-weight: 800; color: #1e40af;">0</div>
                    <div style="font-size: 0.85rem; color: #475569; font-weight: 600;">Danh mục đã thêm</div>
                </div>
                <div style="border-left: 1px solid #bfdbfe;"></div>
                <div>
                    <div id="resultProdsCount" style="font-size: 1.8rem; font-weight: 800; color: #15803d;">0</div>
                    <div style="font-size: 0.85rem; color: #475569; font-weight: 600;">Sản phẩm đã xử lý</div>
                </div>
            </div>
            
            <!-- Danh sách lỗi -->
            <div id="importErrorsBox" style="display: none;">
                <p style="font-weight: 700; color: #b91c1c; font-size: 0.95rem; margin-bottom: 8px;"><i class="fas fa-exclamation-triangle"></i> Chi tiết dòng bỏ qua do lỗi:</p>
                <div id="importErrorsList" style="max-height: 200px; overflow-y: auto; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px; font-size: 0.85rem; color: #991b1b; line-height: 1.6;">
