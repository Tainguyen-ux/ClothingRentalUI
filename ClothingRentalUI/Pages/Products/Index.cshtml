@page
@model ClothingRentalUI.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<style>
    /* Card Layout */
    .data-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .card-title-group h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-title-group p {
        font-size: 0.88rem;
        color: #64748b;
    }
    
    .filter-container {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
        background: #f8fafc;
        padding: 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

    .form-control {
        padding: 10px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .btn-search {
        background-color: #0f172a;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-search:hover {
        background-color: #334155;
    }

    .btn-primary {
        background-color: #3b82f6;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background-color: #2563eb;
        transform: translateY(-1px);
    }

    .table-responsive {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 600px;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .custom-table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
    }

    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }

    .code-prefix {
        font-weight: 700;
        color: #1d4ed8;
        background: #eff6ff;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: monospace;
        display: inline-block;
        margin-bottom: 4px;
        white-space: nowrap;
    }
    
    .product-img {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #e2e8f0;
    }

    /* Pagination */
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding: 10px 0;
    }
    
    .pagination-info {
        font-size: 0.9rem;
        color: #64748b;
    }
    
    .pagination-controls {
        display: flex;
        gap: 8px;
    }
    
    .btn-page {
        padding: 8px 12px;
        border: 1px solid #e2e8f0;
        background: white;
        border-radius: 6px;
        color: #334155;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .btn-page:hover:not(.disabled) {
        background: #f8fafc;
        border-color: #cbd5e1;
    }
    
    .btn-page.active {
        background: #3b82f6;
        color: white;
        border-color: #3b82f6;
    }
    
    .btn-page.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .status-active { background: #dcfce7; color: #166534; }
    .status-inactive { background: #fee2e2; color: #991b1b; }
    
    .btn-action {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1rem;
        color: #64748b;
        padding: 6px;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .btn-action:hover {
        background: #f1f5f9;
        color: #3b82f6;
    }
</style>

<div class="data-card">
    @Html.AntiForgeryToken()
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Danh sách Sản phẩm</h2>
            <p>Quản lý danh sách hàng hoá đang có trong kho</p>
        </div>
        @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_CREATE"))
        {
            <button onclick="openIframeModal('/Products/Create?popup=true', 'Thêm Sản phẩm mới')" class="btn-primary">
                <i class="fas fa-plus"></i> Thêm Sản phẩm
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div style="background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #bbf7d0;">
            <i class="fas fa-check-circle"></i> @Model.SuccessMessage
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #fecaca;">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <form method="get" class="filter-container">
        <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Tìm theo Mã hoặc Tên..." style="min-width: 250px; flex: 1;" />
        
        <select name="CategoryId" class="form-control" style="min-width: 200px;">
            <option value="">-- Tất cả loại hàng --</option>
            @foreach (var cat in Model.Categories)
            {
                if (Model.CategoryId == cat.Id)
                {
                    <option value="@cat.Id" selected>@cat.Name (@cat.CodePrefix)</option>
                }
                else
                {
                    <option value="@cat.Id">@cat.Name (@cat.CodePrefix)</option>
                }
            }
        </select>
        
        <button type="submit" class="btn-search"><i class="fas fa-search"></i> Tìm kiếm</button>
        <a href="/Products/Index" class="btn-page" style="display: flex; align-items: center; justify-content: center; height: 100%;">Xóa lọc</a>
    </form>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th style="width: 80px; text-align: center;">Ảnh</th>
                    <th style="width: 220px; white-space: nowrap;">Mã SP</th>
                    <th>Tên Sản Phẩm</th>
                    <th style="width: 150px;">Danh Mục</th>
                    <th style="width: 150px;">Thuộc tính</th>
                    <th style="width: 180px;">Tồn kho</th>
                    <th style="width: 180px;">Trạng thái</th>
                    <th style="text-align: right; width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products.Any())
                {
                    int startIndex = (Model.PageIndex - 1) * IndexModel.PageSize + 1;
                    foreach (var item in Model.Products)
                    {
                        <tr>
                            <td style="text-align: center; color: #64748b; font-weight: 500;">@startIndex</td>
                            <td style="text-align: center; vertical-align: middle; padding: 8px;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" style="width: 50px; height: 65px; object-fit: cover; border-radius: 6px; border: 1px solid #cbd5e1; cursor: pointer; display: inline-block;" onclick="openImageUploadModal(@item.Id, '@item.Code', '@item.ImageUrl')" title="Xem / Thay đổi ảnh" />
                                }
                                else
                                {
                                    <div style="width: 50px; height: 65px; background: #f8fafc; border-radius: 6px; border: 1px dashed #cbd5e1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: #94a3b8;" onclick="openImageUploadModal(@item.Id, '@item.Code', '')" title="Tải ảnh lên">
                                        <i class="fas fa-camera"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="code-prefix">@item.Code</span>
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #0f172a;">@item.Name</div>
                            </td>
                            <td>
                                <div style="font-size: 0.85rem; color: #64748b;">
                                    <i class="fas fa-tag"></i> @item.Category?.Name
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Size))
                                {
                                    <span style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; margin-right: 4px;">Size: @item.Size</span>
                                }
                                @if (!string.IsNullOrEmpty(item.Color))
                                {
                                    <span style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem;">Màu: @item.Color</span>
                                }
                            </td>
                            <td>
                                <div style="font-weight: 700; color: @(item.StockQuantity > 0 ? "#16a34a" : "#dc2626")">
                                    @item.StockQuantity chiếc
                                </div>
                                <div style="font-size: 0.8rem; color: #64748b;">
                                    (Đang thuê: @item.RentedQuantity)
                                </div>
                            </td>
                            <td>
                                @if (item.IsLiquidated)
                                {
                                    <span class="status-badge status-inactive">Đã thanh lý</span>
                                }
                                else if (!item.IsAvailable)
                                {
                                    <span class="status-badge" style="background: #fef08a; color: #854d0e;">Tạm khóa</span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">Hoạt động</span>
                                }
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_EDIT"))
                                {
                                    <button onclick="openIframeModal('/Products/Edit?id=@item.Id&popup=true', 'Chỉnh sửa sản phẩm')" class="btn-action" title="Chỉnh sửa sản phẩm">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button onclick="openImageUploadModal(@item.Id, '@item.Code', '@(item.ImageUrl ?? "")')" class="btn-action" title="Tải ảnh lên" style="color: #06b6d4;">
                                        <i class="fas fa-camera"></i>
                                    </button>
                                }
                                
                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_LOCK"))
                                {
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái sản phẩm này?');">
                                        @if (item.IsAvailable)
                                        {
                                            <button type="submit" class="btn-action" title="Tạm khóa sản phẩm" style="color: #ea580c;">
                                                <i class="fas fa-lock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-action" title="Mở khóa sản phẩm" style="color: #16a34a;">
                                                <i class="fas fa-unlock"></i>
                                            </button>
                                        }
                                    </form>
                                }

                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_DELETE"))
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('CẢNH BÁO: Bạn có chắc chắn muốn XÓA VĨNH VIỄN sản phẩm này khỏi hệ thống không? Hành động này không thể hoàn tác!');">
                                        <button type="submit" class="btn-action" title="Xóa sản phẩm" style="color: #dc2626;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }

                                <button class="btn-action" title="Lịch sử thuê" onclick="openRentalHistory(@item.Id, '@item.Code')" style="color: #6366f1;">
                                    <i class="fas fa-history"></i>
                                </button>

                                <button class="btn-action" title="In Barcode" onclick="printBarcode('@item.Code', '@item.Name.Replace("'", "\\'")')" style="color: #475569;">
                                    <i class="fas fa-barcode"></i>
                                </button>
                            </td>
                        </tr>
                        startIndex++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 40px; color: #64748b;">
                            <i class="fas fa-box-open fa-3x" style="color: #cbd5e1; margin-bottom: 12px;"></i>
                            <p>Không tìm thấy sản phẩm nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị trang @Model.PageIndex / @Model.TotalPages (Tổng @Model.TotalItems bản ghi)
            </div>
            <div class="pagination-controls">
                @if (Model.PageIndex > 1)
                {
                    <a href="?pageIndex=@(Model.PageIndex - 1)&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId" class="btn-page">Trước</a>
                }
                else
                {
                    <span class="btn-page disabled">Trước</span>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.PageIndex) <= 2)
                    {
                        <a href="?pageIndex=@i&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId" class="btn-page @(i == Model.PageIndex ? "active" : "")">@i</a>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <span style="padding: 8px;">...</span>
                    }
                }
                
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?pageIndex=@(Model.PageIndex + 1)&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId" class="btn-page">Sau</a>
                }
                else
                {
                    <span class="btn-page disabled">Sau</span>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Lịch sử Thuê -->
<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px);
        display: none; justify-content: center; align-items: center; z-index: 1000;
    }
    .modal-overlay.active { display: flex; }
    .modal-content {
        background: #ffffff; border-radius: 16px; width: 100%; max-width: 650px;
        padding: 24px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        max-height: 90vh; display: flex; flex-direction: column;
    }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 16px; }
    .modal-header h3 { margin: 0; font-size: 1.25rem; font-weight: 700; color: #0f172a; }
    .btn-close { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #64748b; }
    .history-list { overflow-y: auto; flex: 1; margin: 0; padding: 0; list-style: none; }
    .history-item { padding: 12px; border-bottom: 1px solid #f1f5f9; }
    .history-item:last-child { border-bottom: none; }
    .history-date { font-size: 0.8rem; color: #64748b; }
    .history-detail { font-weight: 600; color: #334155; margin-top: 4px; }
</style>

<div id="historyModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 700px;">
        <div class="modal-header">
            <h3 id="historyModalTitle">Lịch sử thuê sản phẩm</h3>
            <button class="btn-close" onclick="document.getElementById('historyModal').classList.remove('active')">✕</button>
        </div>
        
        <!-- Bộ lọc thời gian -->
        <div style="display: flex; gap: 8px; margin-bottom: 16px; align-items: center; flex-wrap: wrap; background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; font-size: 0.9rem;">
            <div style="display: flex; align-items: center; gap: 4px;">
                <label>Từ ngày:</label>
                <input type="date" id="historyStartDate" class="form-control" style="padding: 4px 8px; font-size: 0.85rem;" />
            </div>
            <div style="display: flex; align-items: center; gap: 4px;">
                <label>Đến ngày:</label>
                <input type="date" id="historyEndDate" class="form-control" style="padding: 4px 8px; font-size: 0.85rem;" />
            </div>
            <button onclick="applyHistoryFilter()" class="btn-search" style="padding: 6px 12px; font-size: 0.85rem; border-radius: 6px; cursor: pointer; border: none; background: #0f172a; color: white;">Lọc</button>
            <button onclick="resetHistoryFilter()" class="btn-page" style="padding: 6px 12px; font-size: 0.85rem; border-radius: 6px; cursor: pointer; border: 1px solid #e2e8f0; background: white; color: #334155;">Xóa lọc</button>
        </div>

        <ul id="historyList" class="history-list" style="max-height: 400px;">
            <li style="text-align:center; padding: 20px; color: #64748b;">Đang tải dữ liệu...</li>
        </ul>

        <!-- Phân trang lịch sử -->
        <div id="historyPagination" style="display: flex; justify-content: space-between; align-items: center; margin-top: 16px; border-top: 1px solid #e2e8f0; padding-top: 16px;">
            <div id="historyPaginationInfo" style="font-size: 0.88rem; color: #64748b;"></div>
            <div style="display: flex; gap: 6px;">
                <button id="btnHistoryPrev" onclick="changeHistoryPage(-1)" class="btn-page" style="padding: 4px 10px; font-size: 0.85rem; cursor: pointer;">Trước</button>
                <button id="btnHistoryNext" onclick="changeHistoryPage(1)" class="btn-page" style="padding: 4px 10px; font-size: 0.85rem; cursor: pointer;">Sau</button>
            </div>
        </div>
    </div>
</div>

<!-- Iframe Modal -->
<div id="iframeModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 1200px; height: 90vh; display: flex; flex-direction: column;">
        <div class="modal-header">
            <h3 id="iframeModalTitle"></h3>
            <button class="btn-close" onclick="closeIframeModal()">✕</button>
        </div>
        <div style="flex: 1; padding: 0; position: relative;">
            <div id="iframeLoader" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #64748b;">Đang tải...</div>
            <iframe id="iframeContent" src="" style="width: 100%; height: 100%; border: none; position: relative; z-index: 2;" onload="document.getElementById('iframeLoader').style.display='none'"></iframe>
        </div>
    </div>
</div>

<!-- Modal Tải ảnh lên cho điện thoại -->
<div id="imageUploadModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h3 id="imageUploadModalTitle">Tải ảnh lên sản phẩm</h3>
            <button class="btn-close" onclick="closeImageUploadModal()">✕</button>
        </div>
        
        <div style="text-align: center; margin-bottom: 20px;">
            <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 12px;">Hình ảnh hiện tại:</p>
            <div style="display: inline-block; position: relative; width: 180px; height: 240px; border-radius: 12px; border: 2px dashed #e2e8f0; background: #f8fafc; overflow: hidden; vertical-align: middle; box-shadow: inset 0 2px 4px 0 rgba(0,0,0,0.06);">
                <img id="uploadPreview" src="" style="width: 100%; height: 100%; object-fit: cover; display: none;" />
                <div id="uploadPlaceholder" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #94a3b8; font-size: 0.9rem; width: 100%;">
                    <i class="fas fa-image fa-3x" style="margin-bottom: 8px; display: block; color: #cbd5e1;"></i>
                    Chưa có hình ảnh
                </div>
            </div>
        </div>

        <div style="margin-bottom: 20px;">
            <label class="btn-primary" style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px; cursor: pointer; border-radius: 8px; font-weight: 600;">
                <i class="fas fa-camera"></i> Chọn ảnh / Chụp ảnh
                <input type="file" id="mobileImageInput" accept="image/*" style="display: none;" onchange="previewMobileImage(event)" />
            </label>
        </div>

        <div id="uploadProgressContainer" style="display: none; margin-bottom: 20px; background: #eff6ff; padding: 12px; border-radius: 8px; border: 1px solid #bfdbfe; font-size: 0.9rem; color: #1e40af; text-align: center;">
            <i class="fas fa-spinner fa-spin" style="margin-right: 6px;"></i>
            <span id="uploadProgressText">Đang tải lên...</span>
        </div>

        <div id="uploadErrorMsg" style="display: none; margin-bottom: 20px; background: #fef2f2; padding: 12px; border-radius: 8px; border: 1px solid #fecaca; font-size: 0.9rem; color: #b91c1c; text-align: center;"></div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn-page" onclick="closeImageUploadModal()" style="margin: 0; padding: 10px 16px;">Hủy</button>
            <button id="btnSubmitUpload" class="btn-primary" onclick="startMobileUpload()" style="margin: 0; padding: 10px 16px;" disabled>Tải lên</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
<script>
    function printBarcode(code, name) {
        // Tạo một cửa sổ/frame mới ẩn để chứa Barcode
        const printWindow = window.open('', '_blank', 'width=400,height=300');
        printWindow.document.write(`
            <html>
            <head>
                <title>In Barcode - ${code}</title>
                <style>
                    body { text-align: center; margin: 0; padding: 20px; font-family: sans-serif; }
                    .product-name { font-weight: bold; font-size: 14px; margin-bottom: 10px; }
                    svg { max-width: 100%; height: auto; }
                </style>
                <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"><\/script>
            </head>
            <body>
                <div class="product-name">${name}</div>
                <svg id="barcode"></svg>
                <script>
                    window.onload = function() {
                        JsBarcode("#barcode", "${code}", {
                            format: "CODE128",
                            width: @(Model.BarcodeConfig.Width),
                            height: @(Model.BarcodeConfig.Height),
                            displayValue: true,
                            fontSize: @(Model.BarcodeConfig.FontSize),
                            margin: 10
                        });
                        setTimeout(() => {
                            window.print();
                            window.close();
                        }, 500);
                    };
                <\/script>
            </body>
            </html>
        `);
        printWindow.document.close();
    }

    // Biến toàn cục lưu trạng thái của modal lịch sử
    let historyState = {
        productId: null,
        productCode: '',
        pageIndex: 1,
        startDate: '',
        endDate: ''
    };

    function openRentalHistory(productId, code) {
        historyState.productId = productId;
        historyState.productCode = code;
        historyState.pageIndex = 1;
        
        const today = new Date();
        const year = today.getFullYear();
        const month = String(today.getMonth() + 1).padStart(2, '0');
        const day = String(today.getDate()).padStart(2, '0');
        const todayStr = `${year}-${month}-${day}`;
        
        historyState.startDate = todayStr;
        historyState.endDate = todayStr;
        
        // Đặt giá trị mặc định là ngày hôm nay trên UI
        document.getElementById('historyStartDate').value = todayStr;
        document.getElementById('historyEndDate').value = todayStr;
        
        document.getElementById('historyModalTitle').innerText = 'Lịch sử thuê: ' + code;
        document.getElementById('historyModal').classList.add('active');
        
        loadHistoryData();
    }

    async function loadHistoryData() {
        const list = document.getElementById('historyList');
        list.innerHTML = '<li style="text-align:center; padding: 20px; color: #64748b;">Đang tải dữ liệu...</li>';

        const url = `?handler=RentalHistory&productId=${historyState.productId}&pageIndex=${historyState.pageIndex}&startDate=${historyState.startDate}&endDate=${historyState.endDate}`;
        try {
            const response = await fetch(url);
            if (response.ok) {
                const data = await response.json();
                if (data.success && data.history.length > 0) {
                    list.innerHTML = data.history.map(h => `
                        <li class="history-item" style="border-bottom: 1px solid #f1f5f9; padding: 12px 0;">
                            <div class="history-date" style="font-size: 0.85rem; color: #64748b; display: flex; justify-content: space-between;">
                                <span>Mã Đơn: <b style="color: #1d4ed8;">#${h.orderId}</b> | Khách hàng: <b>${h.customerName}</b></span>
                                <span>Tạo lúc: ${new Date(h.createdAt).toLocaleString()}</span>
                            </div>
                            <div class="history-detail" style="font-weight: 600; color: #334155; margin-top: 6px;">
                                Thuê ${h.rentDays} ngày - Trạng thái: ${h.isReturned ? '<span style="color: #16a34a; background: #dcfce7; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem;">Đã trả</span>' : '<span style="color: #ea580c; background: #ffedd5; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem;">Đang mượn</span>'}
                                ${h.extendedDays > 0 ? ` <span style="color: #2563eb; font-size: 0.85rem;">(Gia hạn thêm ${h.extendedDays} ngày)</span>` : ''}
                            </div>
                        </li>
                    `).join('');
                    
                    // Cập nhật phân trang
                    updateHistoryPaginationUI(data.pageIndex, data.totalPages, data.totalItems);
                } else {
                    list.innerHTML = '<li style="text-align:center; padding: 20px; color: #64748b;">Chưa có lịch sử thuê.</li>';
                    updateHistoryPaginationUI(1, 0, 0);
                }
            } else {
                list.innerHTML = '<li style="text-align:center; padding: 20px; color: #dc2626;">Lỗi tải dữ liệu.</li>';
                updateHistoryPaginationUI(1, 0, 0);
            }
        } catch (e) {
            list.innerHTML = '<li style="text-align:center; padding: 20px; color: #dc2626;">Lỗi tải dữ liệu.</li>';
            updateHistoryPaginationUI(1, 0, 0);
        }
    }

    function updateHistoryPaginationUI(currentPage, totalPages, totalItems) {
        const info = document.getElementById('historyPaginationInfo');
        const btnPrev = document.getElementById('btnHistoryPrev');
        const btnNext = document.getElementById('btnHistoryNext');
        
        if (totalPages <= 1) {
            document.getElementById('historyPagination').style.display = totalItems > 0 ? 'flex' : 'none';
            info.innerText = `Tổng cộng ${totalItems} lượt thuê`;
            btnPrev.disabled = true;
            btnPrev.classList.add('disabled');
            btnNext.disabled = true;
            btnNext.classList.add('disabled');
            return;
        }
        
        document.getElementById('historyPagination').style.display = 'flex';
        info.innerText = `Trang ${currentPage} / ${totalPages} (Tổng ${totalItems} lượt thuê)`;
        
        btnPrev.disabled = currentPage <= 1;
        if (currentPage <= 1) btnPrev.classList.add('disabled'); else btnPrev.classList.remove('disabled');
        
        btnNext.disabled = currentPage >= totalPages;
        if (currentPage >= totalPages) btnNext.classList.add('disabled'); else btnNext.classList.remove('disabled');
    }

    function changeHistoryPage(direction) {
        historyState.pageIndex += direction;
        loadHistoryData();
    }

    function applyHistoryFilter() {
        historyState.startDate = document.getElementById('historyStartDate').value;
        historyState.endDate = document.getElementById('historyEndDate').value;
        historyState.pageIndex = 1; // Reset về trang 1 khi lọc
        loadHistoryData();
    }

    function resetHistoryFilter() {
        document.getElementById('historyStartDate').value = '';
        document.getElementById('historyEndDate').value = '';
        historyState.startDate = '';
        historyState.endDate = '';
        historyState.pageIndex = 1;
        loadHistoryData();
    }

    let isGridDirty = false;

    function openIframeModal(url, title) {
        document.getElementById('iframeModalTitle').innerText = title;
        document.getElementById('iframeLoader').style.display = 'block';
        document.getElementById('iframeContent').src = url;
        document.getElementById('iframeModal').classList.add('active');
        isGridDirty = false;
    }

    function closeIframeModal() {
        document.getElementById('iframeModal').classList.remove('active');
        document.getElementById('iframeContent').src = '';
        if (isGridDirty) {
            window.location.reload();
        }
    }

    window.addEventListener('message', function(event) {
        if (event.data && event.data.type === 'PRODUCT_CREATED') {
            isGridDirty = true;
            // Optionally, we could show a toast here
        }
        else if (event.data && event.data.type === 'PRODUCT_EDITED') {
            isGridDirty = true;
            closeIframeModal(); // Auto close on edit success
        }
    });

    // Image upload modal JS
    let currentUploadProductId = null;
    const uploadUrl = '@Model.UploadUrl';
    const folderId = '@Model.FolderId';

    function openImageUploadModal(productId, code, currentUrl) {
        currentUploadProductId = productId;
        document.getElementById('imageUploadModalTitle').innerText = 'Tải ảnh lên: ' + code;
        document.getElementById('mobileImageInput').value = '';
        
        const preview = document.getElementById('uploadPreview');
        const placeholder = document.getElementById('uploadPlaceholder');
        
        if (currentUrl) {
            preview.src = currentUrl;
            preview.style.display = 'block';
            placeholder.style.display = 'none';
        } else {
            preview.src = '';
            preview.style.display = 'none';
            placeholder.style.display = 'block';
        }
        
        document.getElementById('btnSubmitUpload').disabled = true;
        
        // Reset progress block to defaults
        const progressContainer = document.getElementById('uploadProgressContainer');
        progressContainer.style.display = 'none';
        progressContainer.style.background = '#eff6ff';
        progressContainer.style.borderColor = '#bfdbfe';
        progressContainer.style.color = '#1e40af';
        document.getElementById('uploadProgressText').innerText = 'Đang tải lên...';
        
        document.getElementById('uploadErrorMsg').style.display = 'none';
        document.getElementById('imageUploadModal').classList.add('active');
    }

    function closeImageUploadModal() {
        document.getElementById('imageUploadModal').classList.remove('active');
    }

    function previewMobileImage(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const preview = document.getElementById('uploadPreview');
            const placeholder = document.getElementById('uploadPlaceholder');
            preview.src = e.target.result;
            preview.style.display = 'block';
            placeholder.style.display = 'none';
            document.getElementById('btnSubmitUpload').disabled = false;
        };
        reader.readAsDataURL(file);
    }

    async function startMobileUpload() {
        const fileInput = document.getElementById('mobileImageInput');
        const file = fileInput.files[0];
        if (!file || !currentUploadProductId) return;

        const progressContainer = document.getElementById('uploadProgressContainer');
        const progressText = document.getElementById('uploadProgressText');
        const errorMsg = document.getElementById('uploadErrorMsg');
        const btnSubmit = document.getElementById('btnSubmitUpload');

        progressContainer.style.display = 'block';
        errorMsg.style.display = 'none';
        btnSubmit.disabled = true;

        if (!uploadUrl) {
            progressContainer.style.display = 'none';
            errorMsg.innerText = 'Lỗi: Chưa cấu hình GoogleAppScript_UploadUrl trong bảng SystemSettings.';
            errorMsg.style.display = 'block';
            btnSubmit.disabled = false;
            return;
        }

        progressText.innerText = 'Đang đọc tệp tin...';

        const reader = new FileReader();
        reader.onload = async function() {
            const base64Data = reader.result.split(',')[1];
            try {
                progressText.innerText = 'Đang tải ảnh lên Google Drive...';
                const uploadRes = await fetch(uploadUrl, {
                    method: 'POST',
                    body: JSON.stringify({
                        filename: file.name,
                        mimeType: file.type,
                        fileData: base64Data,
                        folderId: folderId
                    })
                });

                const uploadResult = await uploadRes.json();
                if (uploadResult && uploadResult.success && uploadResult.url) {
                    const imageUrl = uploadResult.url;
                    
                    progressText.innerText = 'Đang cập nhật hình ảnh vào cơ sở dữ liệu...';
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const updateRes = await fetch('?handler=UpdateImageAjax', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            ProductId: currentUploadProductId,
                            Url: imageUrl
                        })
                    });

                    const updateResult = await updateRes.json();
                    if (updateResult && updateResult.success) {
                        progressText.innerText = 'Cập nhật thành công!';
                        progressContainer.style.background = '#dcfce7';
                        progressContainer.style.borderColor = '#bbf7d0';
                        progressContainer.style.color = '#15803d';
                        
                        setTimeout(() => {
                            closeImageUploadModal();
                            window.location.reload();
                        }, 1000);
                    } else {
                        throw new Error(updateResult.message || 'Lỗi cập nhật CSDL.');
                    }
                } else {
                    throw new Error(uploadResult.error || 'Lỗi tải ảnh lên Google Apps Script.');
                }
            } catch (err) {
                console.error(err);
                progressContainer.style.display = 'none';
                errorMsg.innerText = 'Lỗi: ' + err.message;
                errorMsg.style.display = 'block';
                btnSubmit.disabled = false;
            }
        };
        reader.onerror = () => {
            progressContainer.style.display = 'none';
            errorMsg.innerText = 'Lỗi đọc tệp tin.';
            errorMsg.style.display = 'block';
            btnSubmit.disabled = false;
        };
        reader.readAsDataURL(file);
    }
</script>
