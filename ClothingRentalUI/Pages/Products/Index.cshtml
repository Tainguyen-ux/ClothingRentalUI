@page
@model ClothingRentalUI.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<style>
    /* Card Layout */
    .data-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .card-title-group h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-title-group p {
        font-size: 0.88rem;
        color: #64748b;
    }
    
    .filter-container {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
        background: #f8fafc;
        padding: 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }

    .form-control {
        padding: 10px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .btn-search {
        background-color: #0f172a;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-search:hover {
        background-color: #334155;
    }

    .btn-primary {
        background-color: #3b82f6;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background-color: #2563eb;
        transform: translateY(-1px);
    }

    .table-responsive {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 600px;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .custom-table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
    }

    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }

    .code-prefix {
        font-weight: 700;
        color: #1d4ed8;
        background: #eff6ff;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: monospace;
        display: inline-block;
        margin-bottom: 4px;
        white-space: nowrap;
    }
    
    .product-img {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #e2e8f0;
    }

    /* Pagination */
    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding: 10px 0;
    }
    
    .pagination-info {
        font-size: 0.9rem;
        color: #64748b;
    }
    
    .pagination-controls {
        display: flex;
        gap: 8px;
    }
    
    .btn-page {
        padding: 8px 12px;
        border: 1px solid #e2e8f0;
        background: white;
        border-radius: 6px;
        color: #334155;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .btn-page:hover:not(.disabled) {
        background: #f8fafc;
        border-color: #cbd5e1;
    }
    
    .btn-page.active {
        background: #3b82f6;
        color: white;
        border-color: #3b82f6;
    }
    
    .btn-page.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .status-active { background: #dcfce7; color: #166534; }
    .status-inactive { background: #fee2e2; color: #991b1b; }
    
    .btn-action {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1rem;
        color: #64748b;
        padding: 6px;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .btn-action:hover {
        background: #f1f5f9;
        color: #3b82f6;
    }
</style>

<div class="data-card">
    @Html.AntiForgeryToken()
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Danh sách Sản phẩm</h2>
            <p>Quản lý danh sách hàng hoá đang có trong kho</p>
        </div>
        @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_CREATE"))
        {
            <div style="display: flex; gap: 10px; align-items: center;">
                <button onclick="openImportExcelModal()" class="btn-page" style="display: inline-flex; align-items: center; gap: 8px; font-weight: 600; padding: 10px 16px; border: 1px solid #16a34a; background: #f0fdf4; color: #166534; cursor: pointer; border-radius: 8px; transition: all 0.2s;">
                    <i class="fas fa-file-excel" style="color: #16a34a; font-size: 1.1rem;"></i> Nhập từ Excel
                </button>
                <button onclick="openIframeModal('/Products/Create?popup=true', 'Thêm Sản phẩm mới')" class="btn-primary">
                    <i class="fas fa-plus"></i> Thêm Sản phẩm
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div style="background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #bbf7d0;">
            <i class="fas fa-check-circle"></i> @Model.SuccessMessage
        </div>
    }
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #fecaca;">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <form method="get" class="filter-container">
        <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Tìm theo Mã hoặc Tên..." style="min-width: 250px; flex: 1;" />
        
        <select name="CategoryId" class="form-control" style="min-width: 200px;">
            <option value="">-- Tất cả loại hàng --</option>
            @foreach (var cat in Model.Categories)
            {
                if (Model.CategoryId == cat.Id)
                {
                    <option value="@cat.Id" selected>@cat.Name (@cat.CodePrefix)</option>
                }
                else
                {
                    <option value="@cat.Id">@cat.Name (@cat.CodePrefix)</option>
                }
            }
        </select>
        
        <select name="Status" class="form-control" style="min-width: 180px;">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Active" selected="@(Model.Status == "Active" ? "selected" : null)">Hoạt động</option>
            <option value="Locked" selected="@(Model.Status == "Locked" ? "selected" : null)">Tạm khóa</option>
            <option value="Liquidated" selected="@(Model.Status == "Liquidated" ? "selected" : null)">Đã thanh lý</option>
            <option value="LowStock" selected="@(Model.Status == "LowStock" ? "selected" : null)">⚠️ Cảnh báo tồn kho</option>
        </select>
        
        <button type="submit" class="btn-search"><i class="fas fa-search"></i> Tìm kiếm</button>
        <a href="/Products/Index" class="btn-page" style="display: flex; align-items: center; justify-content: center; height: 100%;">Xóa lọc</a>
    </form>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th style="width: 80px; text-align: center;">Ảnh</th>
                    <th style="width: 220px; white-space: nowrap;">Mã SP</th>
                    <th>Tên Sản Phẩm</th>
                    <th style="width: 150px;">Danh Mục</th>
                    <th style="width: 150px;">Thuộc tính</th>
                    <th style="width: 180px;">Tồn kho</th>
                    <th style="width: 180px;">Trạng thái</th>
                    <th style="text-align: right; width: 120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products.Any())
                {
                    int startIndex = (Model.PageIndex - 1) * IndexModel.PageSize + 1;
                    foreach (var item in Model.Products)
                    {
                        <tr>
                            <td style="text-align: center; color: #64748b; font-weight: 500;">@startIndex</td>
                            <td style="text-align: center; vertical-align: middle; padding: 8px;">
                                @{
                                    var imageUrl = item.ImageUrl;
                                    var imageCount = 0;
                                    var firstImage = "";
                                    if (!string.IsNullOrEmpty(imageUrl))
                                    {
                                        if (imageUrl.Trim().StartsWith("[") && imageUrl.Trim().EndsWith("]"))
                                        {
                                            try
                                            {
                                                var list = System.Text.Json.JsonSerializer.Deserialize<List<string>>(imageUrl);
                                                if (list != null)
                                                {
                                                    imageCount = list.Count;
                                                    firstImage = list.Count > 0 ? list[0] : "";
                                                }
                                            }
                                            catch {}
                                        }
                                        else
                                        {
                                            imageCount = 1;
                                            firstImage = imageUrl;
                                        }
                                    }
                                    var base64ImageUrl = string.IsNullOrEmpty(imageUrl) ? "" : Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(imageUrl));
                                }
                                @if (imageCount > 0)
                                {
                                    <div style="position: relative; display: inline-block; cursor: zoom-in;" onclick="openLightbox('@base64ImageUrl', 0, event)" title="Click để xem ảnh to">
                                        <img src="@IndexModel.GetDirectGoogleDriveImageUrl(firstImage)" style="width: 50px; height: 65px; object-fit: cover; border-radius: 6px; border: 1px solid #cbd5e1; display: block;" />
                                        @if (imageCount > 1)
                                        {
                                            <span style="position: absolute; bottom: -4px; right: -4px; background: #3b82f6; color: white; border-radius: 10px; padding: 1px 6px; font-size: 0.7rem; font-weight: 700; border: 1.5px solid white; box-shadow: 0 1px 2px rgba(0,0,0,0.15);">+@(imageCount - 1)</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="width: 50px; height: 65px; background: #f8fafc; border-radius: 6px; border: 1px dashed #cbd5e1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: #94a3b8;" onclick="openImageUploadModal(@item.Id, '@item.Code', '', true)" title="Tải ảnh lên">
                                        <i class="fas fa-camera"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="code-prefix">@item.Code</span>
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #0f172a;">@item.Name</div>
                            </td>
                            <td>
                                <div style="font-size: 0.85rem; color: #64748b;">
                                    <i class="fas fa-tag"></i> @item.Category?.Name
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Size))
                                {
                                    <span style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; margin-right: 4px;">Size: @item.Size</span>
                                }
                                @if (!string.IsNullOrEmpty(item.Color))
                                {
                                    <span style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem;">Màu: @item.Color</span>
                                }
                            </td>
                            <td>
                                @{
                                    var isLowStock = item.WarningStockLevel > 0 && item.StockQuantity <= item.WarningStockLevel;
                                }
                                <div style="display: flex; align-items: center; gap: 6px;">
                                    <span style="font-weight: 700; color: @(item.StockQuantity > 0 ? (isLowStock ? "#ea580c" : "#16a34a") : "#dc2626")">
                                        @item.StockQuantity chiếc
                                    </span>
                                    @if (isLowStock)
                                    {
                                        <span class="status-badge" style="background: #fff7ed; color: #c2410c; border: 1px solid #ffedd5; font-size: 0.75rem; padding: 2px 6px; display: inline-flex; align-items: center; gap: 4px;" title="Ngưỡng cảnh báo: @item.WarningStockLevel">
                                            <i class="fas fa-exclamation-triangle"></i> Sắp hết
                                        </span>
                                    }
                                </div>
                                <div style="font-size: 0.8rem; color: #64748b;">
                                    (Đang thuê: @item.RentedQuantity)
                                </div>
                            </td>
                            <td>
                                @if (item.IsLiquidated)
                                {
                                    <span class="status-badge status-inactive">Đã thanh lý</span>
                                }
                                else if (!item.IsAvailable)
                                {
                                    <span class="status-badge" style="background: #fef08a; color: #854d0e;">Tạm khóa</span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">Hoạt động</span>
                                }
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_EDIT"))
                                {
                                    <button onclick="openIframeModal('/Products/Edit?id=@item.Id&popup=true', 'Chỉnh sửa sản phẩm')" class="btn-action" title="Chỉnh sửa sản phẩm">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button onclick="openImageUploadModal(@item.Id, '@item.Code', '@base64ImageUrl', true)" class="btn-action" title="Tải ảnh lên" style="color: #06b6d4;">
                                        <i class="fas fa-camera"></i>
                                    </button>
                                }
                                
                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_LOCK"))
                                {
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái sản phẩm này?');">
                                        @if (item.IsAvailable)
                                        {
                                            <button type="submit" class="btn-action" title="Tạm khóa sản phẩm" style="color: #ea580c;">
                                                <i class="fas fa-lock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-action" title="Mở khóa sản phẩm" style="color: #16a34a;">
                                                <i class="fas fa-unlock"></i>
                                            </button>
                                        }
                                    </form>
                                }

                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_DELETE"))
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('CẢNH BÁO: Bạn có chắc chắn muốn XÓA VĨNH VIỄN sản phẩm này khỏi hệ thống không? Hành động này không thể hoàn tác!');">
                                        <button type="submit" class="btn-action" title="Xóa sản phẩm" style="color: #dc2626;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }

                                <button class="btn-action" title="Lịch sử thuê" onclick="openRentalHistory(@item.Id, '@item.Code')" style="color: #6366f1;">
                                    <i class="fas fa-history"></i>
                                </button>

                                <button class="btn-action" title="In Barcode" onclick="printBarcode('@item.Code', '@item.Name.Replace("'", "\\'")')" style="color: #475569;">
                                    <i class="fas fa-barcode"></i>
                                </button>
                            </td>
                        </tr>
                        startIndex++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 40px; color: #64748b;">
                            <i class="fas fa-box-open fa-3x" style="color: #cbd5e1; margin-bottom: 12px;"></i>
                            <p>Không tìm thấy sản phẩm nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị trang @Model.PageIndex / @Model.TotalPages (Tổng @Model.TotalItems bản ghi)
            </div>
            <div class="pagination-controls">
                @if (Model.PageIndex > 1)
                {
                    <a href="?pageIndex=@(Model.PageIndex - 1)&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId&Status=@Model.Status" class="btn-page">Trước</a>
                }
                else
                {
                    <span class="btn-page disabled">Trước</span>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.PageIndex) <= 2)
                    {
                        <a href="?pageIndex=@i&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId&Status=@Model.Status" class="btn-page @(i == Model.PageIndex ? "active" : "")">@i</a>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <span style="padding: 8px;">...</span>
                    }
                }
                
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a href="?pageIndex=@(Model.PageIndex + 1)&SearchTerm=@Model.SearchTerm&CategoryId=@Model.CategoryId&Status=@Model.Status" class="btn-page">Sau</a>
                }
                else
                {
                    <span class="btn-page disabled">Sau</span>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Lịch sử Thuê -->
<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px);
        display: none; justify-content: center; align-items: center; z-index: 1000;
    }
    .modal-overlay.active { display: flex; }
    .modal-content {
        background: #ffffff; border-radius: 16px; width: 100%; max-width: 650px;
        padding: 24px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        max-height: 90vh; display: flex; flex-direction: column;
    }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 16px; }
    .modal-header h3 { margin: 0; font-size: 1.25rem; font-weight: 700; color: #0f172a; }
    .btn-close { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #64748b; }
    .history-list { overflow-y: auto; flex: 1; margin: 0; padding: 0; list-style: none; }
    .history-item { padding: 12px; border-bottom: 1px solid #f1f5f9; }
    .history-item:last-child { border-bottom: none; }
    .history-date { font-size: 0.8rem; color: #64748b; }
    .history-detail { font-weight: 600; color: #334155; margin-top: 4px; }

    /* Lightbox Dot indicators and button hover states */
    .lightbox-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        transition: all 0.2s;
    }
    .lightbox-dot.active {
        background: #ffffff;
        transform: scale(1.2);
    }
    #lightboxPrev:hover, #lightboxNext:hover {
        background: rgba(255, 255, 255, 0.25) !important;
        transform: translateY(-50%) scale(1.1);
    }
</style>

<div id="historyModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 700px;">
        <div class="modal-header">
            <h3 id="historyModalTitle">Lịch sử thuê sản phẩm</h3>
            <button class="btn-close" onclick="document.getElementById('historyModal').classList.remove('active')">✕</button>
        </div>
        
        <!-- Bộ lọc thời gian -->
        <div style="display: flex; gap: 8px; margin-bottom: 16px; align-items: center; flex-wrap: wrap; background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; font-size: 0.9rem;">
            <div style="display: flex; align-items: center; gap: 4px;">
                <label>Từ ngày:</label>
                <input type="date" id="historyStartDate" class="form-control" style="padding: 4px 8px; font-size: 0.85rem;" />
            </div>
            <div style="display: flex; align-items: center; gap: 4px;">
                <label>Đến ngày:</label>
                <input type="date" id="historyEndDate" class="form-control" style="padding: 4px 8px; font-size: 0.85rem;" />
            </div>
            <button onclick="applyHistoryFilter()" class="btn-search" style="padding: 6px 12px; font-size: 0.85rem; border-radius: 6px; cursor: pointer; border: none; background: #0f172a; color: white;">Lọc</button>
            <button onclick="resetHistoryFilter()" class="btn-page" style="padding: 6px 12px; font-size: 0.85rem; border-radius: 6px; cursor: pointer; border: 1px solid #e2e8f0; background: white; color: #334155;">Xóa lọc</button>
        </div>

        <ul id="historyList" class="history-list" style="max-height: 400px;">
            <li style="text-align:center; padding: 20px; color: #64748b;">Đang tải dữ liệu...</li>
        </ul>

        <!-- Phân trang lịch sử -->
        <div id="historyPagination" style="display: flex; justify-content: space-between; align-items: center; margin-top: 16px; border-top: 1px solid #e2e8f0; padding-top: 16px;">
            <div id="historyPaginationInfo" style="font-size: 0.88rem; color: #64748b;"></div>
            <div style="display: flex; gap: 6px;">
                <button id="btnHistoryPrev" onclick="changeHistoryPage(-1)" class="btn-page" style="padding: 4px 10px; font-size: 0.85rem; cursor: pointer;">Trước</button>
                <button id="btnHistoryNext" onclick="changeHistoryPage(1)" class="btn-page" style="padding: 4px 10px; font-size: 0.85rem; cursor: pointer;">Sau</button>
            </div>
        </div>
    </div>
</div>

<!-- Iframe Modal -->
<div id="iframeModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 1200px; height: 90vh; display: flex; flex-direction: column;">
        <div class="modal-header">
            <h3 id="iframeModalTitle"></h3>
            <button class="btn-close" onclick="closeIframeModal()">✕</button>
        </div>
        <div style="flex: 1; padding: 0; position: relative;">
            <div id="iframeLoader" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #64748b;">Đang tải...</div>
            <iframe id="iframeContent" src="" style="width: 100%; height: 100%; border: none; position: relative; z-index: 2;" onload="document.getElementById('iframeLoader').style.display='none'"></iframe>
        </div>
    </div>
</div>

<!-- Modal Tải ảnh lên cho điện thoại -->
<div id="imageUploadModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h3 id="imageUploadModalTitle">Tải ảnh lên sản phẩm</h3>
            <button class="btn-close" onclick="closeImageUploadModal()">✕</button>
        </div>
        
        <!-- Danh sách ảnh hiện có -->
        <div style="margin-bottom: 20px; text-align: left;">
            <p style="font-size: 0.9rem; color: #334155; margin-bottom: 8px; font-weight: 600;">Hình ảnh hiện tại:</p>
            <div id="modalImageList" style="display: flex; gap: 8px; flex-wrap: wrap; max-height: 240px; overflow-y: auto; padding: 8px; border: 1px solid #cbd5e1; border-radius: 8px; background: #f8fafc; min-height: 80px;">
                <!-- JavaScript will populate items here -->
            </div>
        </div>

        <!-- Khung xem trước ảnh mới chọn để tải lên (chỉ hiện khi đã chọn file mới) -->
        <div id="newImagePreviewContainer" style="display: none; text-align: center; margin-bottom: 20px; background: #eff6ff; padding: 12px; border-radius: 8px; border: 1px dashed #3b82f6;">
            <p style="font-size: 0.85rem; color: #1e40af; margin-bottom: 8px; font-weight: 600;">Ảnh mới chuẩn bị tải lên:</p>
            <div id="newUploadPreviewsList" style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; max-height: 200px; overflow-y: auto; padding: 4px;">
                <!-- Previews will go here -->
            </div>
        </div>

        <div style="margin-bottom: 20px;">
            <label class="btn-primary" style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px; cursor: pointer; border-radius: 8px; font-weight: 600;">
                <i class="fas fa-camera"></i> Chọn ảnh / Chụp ảnh
                <input type="file" id="mobileImageInput" accept="image/*" style="display: none;" multiple onchange="previewMobileImage(event)" />
            </label>
        </div>

        <div id="uploadProgressContainer" style="display: none; margin-bottom: 20px; background: #eff6ff; padding: 12px; border-radius: 8px; border: 1px solid #bfdbfe; font-size: 0.9rem; color: #1e40af; text-align: center;">
            <i class="fas fa-spinner fa-spin" style="margin-right: 6px;"></i>
            <span id="uploadProgressText">Đang tải lên...</span>
        </div>

        <div id="uploadErrorMsg" style="display: none; margin-bottom: 20px; background: #fef2f2; padding: 12px; border-radius: 8px; border: 1px solid #fecaca; font-size: 0.9rem; color: #b91c1c; text-align: center;"></div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn-page" onclick="closeImageUploadModal()" style="margin: 0; padding: 10px 16px;">Hủy</button>
            <button id="btnSubmitUpload" class="btn-primary" onclick="startMobileUpload()" style="margin: 0; padding: 10px 16px;" disabled>Tải lên</button>
        </div>
    </div>
</div>

<!-- Lightbox Modal phóng to ảnh (có carousel chuyển ảnh) -->
<div id="imageLightbox" class="modal-overlay" style="z-index: 99999; background: rgba(15, 23, 42, 0.95); cursor: zoom-out;" onclick="closeLightbox()">
    <button class="btn-close" style="position: absolute; top: 24px; right: 24px; color: white; font-size: 2.2rem; background: none; border: none; cursor: pointer; text-shadow: 0 2px 4px rgba(0,0,0,0.5); z-index: 100001;" onclick="closeLightbox()">✕</button>
    
    <!-- Nút Trước -->
    <button id="lightboxPrev" onclick="event.stopPropagation(); navigateLightbox(-1);" style="position: absolute; left: 24px; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.1); border: none; width: 50px; height: 50px; border-radius: 50%; color: white; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; z-index: 100000; outline: none;">
        <i class="fas fa-chevron-left"></i>
    </button>
    
    <!-- Khung hiển thị ảnh -->
    <div style="position: relative; max-width: 90%; max-height: 80vh; display: flex; justify-content: center; align-items: center;" onclick="event.stopPropagation();">
        <img id="lightboxImg" src="" style="max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: 8px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.55); border: 2px solid rgba(255,255,255,0.1); transition: transform 0.25s ease;" />
    </div>

    <!-- Nút Sau -->
    <button id="lightboxNext" onclick="event.stopPropagation(); navigateLightbox(1);" style="position: absolute; right: 24px; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.1); border: none; width: 50px; height: 50px; border-radius: 50%; color: white; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; z-index: 100000; outline: none;">
        <i class="fas fa-chevron-right"></i>
    </button>
    
    <!-- Dấu chấm chỉ số ảnh -->
    <div id="lightboxDots" style="position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 100000;">
        <!-- Dots rendered via JavaScript -->
    </div>
</div>

<!-- Modal Nhập từ Excel -->
<div id="importExcelModal" class="modal-overlay">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h3>Nhập hàng từ Excel</h3>
            <button class="btn-close" onclick="closeImportExcelModal()">✕</button>
        </div>
        
        <!-- Hướng dẫn & Tải file -->
        <div id="importFormContainer">
            <div style="background: #f8fafc; padding: 14px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; border: 1px solid #e2e8f0; color: #475569;">
                <p style="font-weight: 600; color: #1e293b; margin-bottom: 6px;"><i class="fas fa-info-circle" style="color: #3b82f6;"></i> Lưu ý định dạng file:</p>
                <ul style="margin: 0; padding-left: 20px; line-height: 1.5;">
                    <li>File phải có sheet chứa <strong>Danh mục loại hàng</strong> (cột: mã loại hàng, tên loại hàng, mã giá tiền).</li>
                    <li>File phải có sheet chứa <strong>Danh sách sản phẩm</strong> (cột: mã loại hàng, mã hàng, tên hàng, số lượng, giá nhập, giá cho thuê...).</li>
                    <li>Danh mục sẽ luôn được import trước để đảm bảo tính liên kết dữ liệu.</li>
                    <li>Các dòng lỗi sẽ tự động bị bỏ qua và ghi nhận lại lỗi chi tiết bên dưới.</li>
                </ul>
            </div>
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem; color: #1e293b;">Chọn tệp tin Excel (.xlsx, .xls):</label>
                <div style="border: 2px dashed #cbd5e1; border-radius: 12px; padding: 30px 20px; text-align: center; background: #fafafa; cursor: pointer; transition: all 0.2s;" 
                     onclick="document.getElementById('excelFileInput').click()"
                     ondragover="event.preventDefault(); this.style.borderColor='#3b82f6'; this.style.background='#eff6ff';"
                     ondragleave="event.preventDefault(); this.style.borderColor='#cbd5e1'; this.style.background='#fafafa';"
                     ondrop="event.preventDefault(); this.style.borderColor='#cbd5e1'; this.style.background='#fafafa'; handleExcelFileDrop(event);">
                    <i class="fas fa-file-excel fa-3x" style="color: #16a34a; margin-bottom: 12px;"></i>
                    <p id="excelFilePlaceholder" style="font-size: 0.95rem; color: #64748b; margin: 0;">Kéo thả tệp tin vào đây hoặc click để duyệt file</p>
                    <input type="file" id="excelFileInput" accept=".xlsx, .xls" style="display: none;" onchange="handleExcelFileSelected(event)" />
