            <button id="btnSubmitImport" class="btn-primary" onclick="submitImportExcel()" style="margin: 0; padding: 10px 18px; background: #16a34a;" disabled>Bắt đầu nhập</button>
            <button id="btnReloadPage" class="btn-primary" onclick="window.location.reload()" style="margin: 0; padding: 10px 18px; display: none;">Hoàn tất & Tải lại trang</button>
