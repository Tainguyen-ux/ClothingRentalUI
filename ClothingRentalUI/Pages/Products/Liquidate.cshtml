@page
@model ClothingRentalUI.Pages.Products.LiquidateModel
@{
    ViewData["Title"] = "Quản lý phiếu thanh lý";
}

<style>
    .data-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .card-title-group h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .card-title-group p {
        font-size: 0.88rem;
        color: #64748b;
    }

    .filter-container {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
        background: #f8fafc;
        padding: 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        align-items: center;
    }

    .form-control {
        padding: 10px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .btn-search {
        background-color: #0f172a;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-search:hover {
        background-color: #334155;
    }

    .btn-create {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.2);
    }

    .btn-create:hover {
        background: linear-gradient(135deg, #f87171, #ef4444);
        box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.3);
    }

    .table-responsive {
        overflow-x: auto;
        border-radius: 12px;
        border: 1px solid #f1f5f9;
        margin-bottom: 20px;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 0.95rem;
    }

    .custom-table th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .custom-table td {
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        vertical-align: middle;
    }

    .custom-table tbody tr:hover {
        background-color: #f8fafc;
    }

    .code-prefix {
        font-weight: 700;
        color: #ef4444;
        background: #fff5f5;
        padding: 4px 8px;
        border-radius: 6px;
        font-family: monospace;
        display: inline-block;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 700;
        display: inline-block;
    }
    .status-completed {
        background: #dcfce7;
        color: #15803d;
    }
    .status-cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    .pagination-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .pagination-info {
        font-size: 0.9rem;
        color: #64748b;
    }

    .pagination-controls {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .btn-page {
        padding: 8px 14px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background: #ffffff;
        color: #334155;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.88rem;
        transition: all 0.2s;
        cursor: pointer;
        display: inline-block;
    }

    .btn-page:hover:not(.disabled) {
        background: #f1f5f9;
        border-color: #94a3b8;
    }

    .btn-page.active {
        background: #0f172a;
        color: #ffffff;
        border-color: #0f172a;
    }

    .btn-page.disabled {
        color: #94a3b8;
        background: #f8fafc;
        border-color: #e2e8f0;
        cursor: not-allowed;
    }

    /* Modal dialog styling */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease-in-out;
    }
    .modal-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }
    .modal-box {
        background: white;
        border-radius: 16px;
        width: 1100px;
        max-width: 95%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        padding: 24px;
        transform: scale(0.95);
        transition: transform 0.2s ease-in-out;
    }
    .modal-overlay.active .modal-box {
        transform: scale(1);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 16px;
        margin-bottom: 20px;
    }
    .modal-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .modal-close {
        background: none;
        border: none;
        color: #64748b;
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.15s;
    }
    .modal-close:hover {
        color: #0f172a;
    }
    .roi-badge {
        padding: 2px 6px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 700;
    }
    .roi-high { background: #dcfce7; color: #15803d; }
    .roi-mid { background: #fef3c7; color: #b45309; }
    .roi-low { background: #fee2e2; color: #b91c1c; }
</style>

<div class="data-card">
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Quản lý Phiếu thanh lý sản phẩm</h2>
            <p>Tạo phiếu và lưu trữ lịch sử thanh lý các trang phục cũ nát, hết hạn sử dụng</p>
        </div>
        @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_LIQUIDATE_CREATE") || Model.CurrentUserPermissions.Contains("CLOTHES_LIQUIDATE"))
        {
            <div>
                <a href="/Products/LiquidateCreate" class="btn-create">
                    <i class="fas fa-plus"></i> Tạo phiếu thanh lý mới
                </a>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div style="background: #dcfce7; color: #15803d; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #bbf7d0; font-weight: 500;">
            ✅ @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div style="background: #fee2e2; color: #b91c1c; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #fecaca; font-weight: 500;">
            ❌ @Model.ErrorMessage
        </div>
    }

    <!-- Bộ lọc tìm kiếm -->
    <form method="get" class="filter-container">
        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 4px;">Từ ngày:</label>
            <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        
        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 4px;">Đến ngày:</label>
            <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>

        <div style="display: flex; flex-direction: column; flex: 1; min-width: 200px;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; margin-bottom: 4px;">Tìm theo mã phiếu hoặc ghi chú:</label>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Mã TL260... hoặc nội dung ghi chú..." />
        </div>
        
        <div style="display: flex; align-items: flex-end; margin-bottom: 2px;">
            <button type="submit" class="btn-search"><i class="fas fa-filter"></i> Lọc phiếu</button>
            <button type="submit" name="handler" value="ExportExcel" class="btn-search" style="margin-left: 8px; background: #16a34a;"><i class="fas fa-file-excel"></i> Xuất Excel</button>
            <a href="/Products/Liquidate" class="btn-page" style="margin-left: 8px; display: inline-flex; align-items: center; justify-content: center; height: 38px;">Xóa bộ lọc</a>
        </div>
    </form>

    <!-- Bảng danh sách phiếu -->
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">STT</th>
                    <th>Mã phiếu</th>
                    <th>Ngày thanh lý</th>
                    <th style="text-align: center;">Mặt hàng</th>
                    <th style="text-align: center;">Tổng số lượng</th>
                    <th>Người thực hiện</th>
                    <th>Ghi chú</th>
                    <th style="text-align: center;">Trạng thái</th>
                    <th style="width: 180px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.LiquidationOrders.Any())
                {
                    int idx = (Model.PageIndex - 1) * LiquidateModel.PageSize + 1;
                    foreach (var item in Model.LiquidationOrders)
                    {
                        var totalQty = item.LiquidationOrderDetails.Sum(d => d.Quantity);
                        var isCancelled = item.Status == "Cancelled";

                        <tr>
                            <td style="text-align: center; color: #64748b; font-weight: 500;">@idx</td>
                            <td><span class="code-prefix">@item.Code</span></td>
                            <td>@item.LiquidationDate.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="text-align: center; font-weight: 600;">@item.LiquidationOrderDetails.Count</td>
                            <td style="text-align: center; font-weight: 700; color: #dc2626;">@totalQty</td>
                            <td><i class="fas fa-user-circle" style="color: #94a3b8; margin-right: 4px;"></i>@(item.CreatedByUser?.FullName ?? "N/A")</td>
                            <td style="color: #475569; font-size: 0.9rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@item.Notes</td>
                            <td style="text-align: center;">
                                @if (isCancelled)
                                {
                                    <span class="status-badge status-cancelled">Đã hủy</span>
                                }
                                else
                                {
                                    <span class="status-badge status-completed">Hoàn thành</span>
                                }
                            </td>
                            <td style="text-align: center;">
                                <button type="button" class="btn-page" onclick="viewDetails(@item.Id)" style="padding: 6px 12px; font-size: 0.82rem;">
                                    <i class="fas fa-eye"></i> Xem
                                </button>
                                @if (!isCancelled && (Model.IsAdmin || Model.CurrentUserPermissions.Contains("CLOTHES_LIQUIDATE_CANCEL") || Model.CurrentUserPermissions.Contains("CLOTHES_LIQUIDATE")))
                                {
                                    <form method="post" asp-page-handler="Cancel" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn hủy phiếu thanh lý này? Tồn kho của các sản phẩm liên quan sẽ được khôi phục trở lại.');">
                                        <button type="submit" class="btn-page" style="padding: 6px 12px; font-size: 0.82rem; color: #dc2626; border-color: #fca5a5; background: #fff5f5; margin-left: 4px;">
                                            <i class="fas fa-undo"></i> Hủy
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                        idx++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 40px; color: #64748b;">
                            <i class="fas fa-folder-open fa-3x" style="color: #cbd5e1; margin-bottom: 12px;"></i>
                            <p>Không tìm thấy phiếu thanh lý nào phù hợp.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Phân trang -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Hiển thị trang <b>@Model.PageIndex</b> / <b>@Model.TotalPages</b> (Tổng <b>@Model.TotalItems</b> phiếu)
            </div>
            <div class="pagination-controls">
                <a href="?PageIndex=1&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))&SearchTerm=@Model.SearchTerm" class="btn-page @(Model.PageIndex == 1 ? "disabled" : "")">«</a>
                <a href="?PageIndex=@(Model.PageIndex - 1)&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))&SearchTerm=@Model.SearchTerm" class="btn-page @(Model.PageIndex == 1 ? "disabled" : "")">‹</a>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    if (p == 1 || p == Model.TotalPages || Math.Abs(p - Model.PageIndex) <= 2)
                    {
                        <a href="?PageIndex=@p&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))&SearchTerm=@Model.SearchTerm" class="btn-page @(Model.PageIndex == p ? "active" : "")">@p</a>
                    }
                }
                <a href="?PageIndex=@(Model.PageIndex + 1)&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))&SearchTerm=@Model.SearchTerm" class="btn-page @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">›</a>
                <a href="?PageIndex=@Model.TotalPages&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))&SearchTerm=@Model.SearchTerm" class="btn-page @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">»</a>
            </div>
        </div>
    }
</div>

<!-- Modal Chi Tiết Phiếu Thanh Lý -->
<div class="modal-overlay" id="detailModal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title">
                <i class="fas fa-file-invoice" style="color: #ef4444;"></i>
                <span>Chi tiết phiếu thanh lý: <span id="lblOrderCode" style="color: #ef4444;"></span></span>
            </div>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; background: #f8fafc; padding: 14px; border-radius: 8px; border: 1px solid #e2e8f0; font-size: 0.92rem;">
            <div>
                <strong>Ngày thực hiện:</strong> <span id="lblOrderDate"></span>
            </div>
            <div>
                <strong>Người thực hiện:</strong> <span id="lblOrderCreator"></span>
            </div>
            <div style="grid-column: span 2;">
                <strong>Ghi chú:</strong> <span id="lblOrderNotes"></span>
            </div>
        </div>

        <table class="custom-table" style="font-size: 0.9rem;">
            <thead>
                <tr style="background-color: #f1f5f9;">
                    <th>Mã sản phẩm</th>
                    <th>Tên sản phẩm</th>
                    <th>Kích thước/Màu</th>
                    <th style="text-align: center;">SL T.Lý</th>
                    <th style="text-align: right;">Giá nhập</th>
                    <th style="text-align: right;">Lũy kế thuê</th>
                    <th style="text-align: center;">Hiệu suất</th>
                    <th>Lý do thanh lý</th>
                </tr>
            </thead>
            <tbody id="detailTableBody">
                <!-- Dữ liệu load bằng AJAX -->
            </tbody>
        </table>

        <div style="margin-top: 24px; text-align: right;">
            <button type="button" class="btn-search" onclick="closeModal()">Đóng cửa sổ</button>
        </div>
    </div>
</div>

<script>
    async function viewDetails(orderId) {
        try {
            const res = await fetch(`?handler=OrderDetailAjax&id=${orderId}`);
            const data = await res.json();
            if (data.success) {
                document.getElementById('lblOrderCode').textContent = data.code;
                document.getElementById('lblOrderDate').textContent = data.date;
                document.getElementById('lblOrderCreator').textContent = data.creator;
                document.getElementById('lblOrderNotes').textContent = data.notes;

                const body = document.getElementById('detailTableBody');
                body.innerHTML = data.items.map(item => {
                    const roi = item.importPrice > 0 ? (item.rentRevenue / item.importPrice * 100) : 0;
                    const roiClass = roi >= 100 ? "roi-high" : (roi >= 50 ? "roi-mid" : "roi-low");

                    return `
                        <tr>
                            <td><span class="code-prefix" style="font-size: 0.8rem;">${item.productCode}</span></td>
                            <td style="font-weight: 600;">${item.productName}</td>
                            <td style="color: #64748b; font-size: 0.85rem;">Size: ${item.size} | Màu: ${item.color}</td>
                            <td style="text-align: center; font-weight: 700; color: #dc2626;">${item.quantity}</td>
                            <td style="text-align: right;">${item.importPrice.toLocaleString()}₫</td>
                            <td style="text-align: right; color: #16a34a; font-weight: 600;">${item.rentRevenue.toLocaleString()}₫</td>
                            <td style="text-align: center;">
                                <span class="roi-badge ${roiClass}">
                                    ${roi.toFixed(0)}%
                                </span>
                            </td>
                            <td style="color: #475569; font-size: 0.85rem;">${item.reason}</td>
                        </tr>
                    `;
                }).join('');

                document.getElementById('detailModal').classList.add('active');
            } else {
                alert(data.message || 'Có lỗi xảy ra khi lấy chi tiết phiếu.');
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ.');
        }
    }

    function closeModal() {
        document.getElementById('detailModal').classList.remove('active');
    }

    // Đóng modal khi click ra ngoài vùng modal box
    document.getElementById('detailModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeModal();
        }
    });
</script>
