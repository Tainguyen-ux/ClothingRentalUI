@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@inject ClothingRentalUI.Data.ClothingRentalDbContext DbContext
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var fullName = HttpContextAccessor.HttpContext?.Session.GetString("FullName") ?? "Nhân viên";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "Staff";

    List<ClothingRentalUI.Data.Entities.Menu> userMenus = new();

    if (!string.IsNullOrEmpty(username))
    {
        // 1. Lấy thông tin user cùng quyền
        var user = DbContext.Users
            .Include(u => u.UserPermissions)
            .FirstOrDefault(u => u.Username.ToLower() == username.ToLower());

        if (user != null)
        {
            var permissionIds = user.UserPermissions.Select(up => up.PermissionId).ToList();

            // 2. Lọc tất cả menu người dùng được phép xem
            var allAllowedMenus = DbContext.Menus
                .Where(m => m.RequiredPermissionId == null || permissionIds.Contains(m.RequiredPermissionId.Value))
                .OrderBy(m => m.DisplayOrder)
                .ToList();

            // 3. Phân tách menu cha và menu con
            userMenus = allAllowedMenus.Where(m => m.ParentId == null).ToList();
            foreach (var parent in userMenus)
            {
                parent.SubMenus = allAllowedMenus.Where(m => m.ParentId == parent.Id).ToList();
            }
        }
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống Quản lý Cửa hàng</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <style>
        :root {
            --sidebar-width: 280px;
            --primary-grad: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
            --sidebar-bg: #ffffff;
            --content-bg: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --sidebar-border: #e2e8f0;
            --transition-speed: 0.3s;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--content-bg);
            color: #0f172a;
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Global Table Styles */
        th {
            text-align: left !important;
        }

        /* Sidebar Container */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            transition: width var(--transition-speed) ease;
            border-right: 1px solid var(--sidebar-border);
        }

        /* Sidebar Header */
        .sidebar-brand-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 24px;
            border-bottom: 1px solid var(--sidebar-border);
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        .btn-toggle-sidebar {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.2s, transform 0.2s;
            width: 28px;
            height: 28px;
            border-radius: 6px;
        }

        .btn-toggle-sidebar:hover {
            background: #f1f5f9;
            color: #2563eb;
        }

        /* Desktop Collapse State Styles */
        .sidebar.collapsed {
            width: 78px;
        }
        .sidebar.collapsed .brand-full {
            display: none !important;
        }
        .sidebar.collapsed .brand-short {
            display: block !important;
        }
        .sidebar.collapsed .btn-toggle-sidebar {
            margin: 0 auto;
        }
        .sidebar.collapsed .user-profile {
            padding: 20px 0;
            justify-content: center;
        }
        .sidebar.collapsed .profile-info {
            display: none !important;
        }
        .sidebar.collapsed .menu-text,
        .sidebar.collapsed .submenu-text,
        .sidebar.collapsed .menu-arrow {
            display: none !important;
        }
        .sidebar.collapsed .submenu-list {
            display: none !important;
        }
        .sidebar.collapsed .logout-text {
            display: none !important;
        }
        .sidebar.collapsed .btn-logout {
            padding: 12px 0;
            justify-content: center;
        }

        /* Initial Class to prevent UI flash on load */
        html.sidebar-collapsed-init .sidebar {
            width: 78px;
        }
        html.sidebar-collapsed-init .main-wrapper {
            margin-left: 78px;
        }
        html.sidebar-collapsed-init .brand-full,
        html.sidebar-collapsed-init .profile-info,
        html.sidebar-collapsed-init .menu-text,
        html.sidebar-collapsed-init .submenu-text,
        html.sidebar-collapsed-init .menu-arrow,
        html.sidebar-collapsed-init .submenu-list,
        html.sidebar-collapsed-init .logout-text {
            display: none !important;
        }
        html.sidebar-collapsed-init .brand-short {
            display: block !important;
        }
        html.sidebar-collapsed-init .user-profile {
            padding: 20px 0;
            justify-content: center;
        }
        html.sidebar-collapsed-init .btn-logout {
            padding: 12px 0;
            justify-content: center;
        }
        html.sidebar-collapsed-init .btn-toggle-sidebar i {
            transform: rotate(180deg);
        }

        .user-profile {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--sidebar-border);
            text-decoration: none;
            color: inherit;
            transition: all 0.2s ease;
        }

        .user-profile:hover {
            background: rgba(37, 99, 235, 0.05);
            cursor: pointer;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: var(--primary-grad);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.2rem;
            color: #ffffff;
        }

        .profile-info {
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .profile-name {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-main);
            white-space: nowrap;
            text-overflow: ellipsis;
            overflow: hidden;
        }

        .profile-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Navigation List */
        .sidebar-menu {
            list-style: none;
            padding: 20px 12px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
        }

        .menu-item {
            width: 100%;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .menu-link:hover {
            color: #2563eb;
            background: rgba(37, 99, 235, 0.05);
            transform: translateX(4px);
        }

        .menu-link.active {
            color: #ffffff;
            background: var(--primary-grad);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
        }

        .menu-icon {
            font-size: 1.1rem;
        }

        /* Submenu Styling */
        .menu-parent-label {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--text-main);
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            user-select: none;
            border-radius: 10px;
            margin-top: 4px;
            transition: all 0.2s ease;
        }

        .menu-parent-label:hover {
            color: #2563eb;
            background: rgba(37, 99, 235, 0.05);
        }

        .menu-parent-label .menu-arrow {
            margin-left: auto;
            font-size: 0.75rem;
            opacity: 0.7;
            transition: transform 0.2s ease;
        }

        .submenu-list {
            list-style: none;
            padding-left: 12px;
            margin-top: 4px;
            display: none; /* Hide by default, shown when expanded */
            flex-direction: column;
            gap: 4px;
            border-left: 1px dashed #cbd5e1;
            margin-left: 24px;
        }

        .submenu-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.88rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .submenu-link:hover {
            color: #2563eb;
            background: rgba(37, 99, 235, 0.05);
        }

        .submenu-link.active {
            color: #2563eb;
            background: rgba(37, 99, 235, 0.08);
            font-weight: 600;
        }

        /* Logout Section */
        .sidebar-footer {
            padding: 16px;
            border-top: 1px solid var(--sidebar-border);
        }

        .btn-logout {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px;
            background: rgba(239, 68, 68, 0.05);
            color: #ef4444;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            border: 1px solid rgba(239, 68, 68, 0.1);
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            border-color: #ef4444;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
        }

        /* Main Workspace Container */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            flex-grow: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--transition-speed) ease;
        }

        .main-wrapper.collapsed {
            margin-left: 78px;
        }

        /* Top Header Bar */
        .topbar {
            height: 70px;
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 32px;
        }

        .page-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
        }

        .system-date {
            font-size: 0.88rem;
            color: #64748b;
            font-weight: 500;
        }

        /* Page Content Panel */
        .content-panel {
            padding: 32px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        /* Styles for clean views without sidebar (e.g. login page) */
        .no-sidebar {
            margin-left: 0;
            width: 100%;
        }

        /* Hamburger toggle (hidden on desktop) */
        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            font-size: 1.4rem;
            color: #0f172a;
            cursor: pointer;
            padding: 6px;
            border-radius: 8px;
            transition: background 0.2s;
        }
        .hamburger-btn:hover { background: #f1f5f9; }

        /* Mobile overlay */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(15,23,42,0.5);
            backdrop-filter: blur(2px);
            z-index: 99;
        }
        .sidebar-overlay.active { display: block; }

        /* ========== RESPONSIVE ========== */
        @@media (max-width: 768px) {
            .hamburger-btn { display: block; }

            .sidebar {
                transform: translateX(-100%);
                box-shadow: none;
            }
            .sidebar.open {
                transform: translateX(0);
                box-shadow: 4px 0 20px rgba(0,0,0,0.15);
            }

            .main-wrapper {
                margin-left: 0;
            }

            .topbar {
                padding: 0 16px;
                height: 56px;
            }
            .topbar .page-title { font-size: 1rem; }
            .topbar .system-date { font-size: 0.78rem; }

            .content-panel {
                padding: 16px;
            }
        }
    </style>
</head>
<body>
    @if (!string.IsNullOrEmpty(username))
    {
        <script>
            (function() {
                var isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
                if (isCollapsed && window.innerWidth > 768) {
                    document.documentElement.classList.add('sidebar-collapsed-init');
                }
            })();
        </script>

        <!-- Left Dynamic Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand-wrapper">
                <div class="sidebar-brand">
                    <span class="brand-full">9495Comi</span>
                    <span class="brand-short" style="display:none; font-weight:800; background:linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">9495</span>
                </div>
                <button id="toggleSidebarDesktopBtn" class="btn-toggle-sidebar" onclick="toggleSidebarDesktop()" title="Đóng/Mở thanh điều hướng">
                    <i class="fas fa-chevron-left"></i>
                </button>
            </div>

            <a href="/Settings/Profile" class="user-profile">
                <div class="profile-avatar">
                    👤
                </div>
                <div class="profile-info">
                    <span class="profile-name">@fullName</span>
                    <span class="profile-role">@role</span>
                </div>
            </a>

            <nav style="flex-grow: 1; display: flex; flex-direction: column;">
                <ul class="sidebar-menu">
                    @foreach (var item in userMenus)
                    {
                        var isActive = HttpContextAccessor.HttpContext?.Request.Path.Value?.StartsWith(item.Url) == true;
                        
                        @if (item.SubMenus.Any())
                        {
                            var isChildActive = item.SubMenus.Any(sub => HttpContextAccessor.HttpContext?.Request.Path.Value?.StartsWith(sub.Url) == true);
                            <li class="menu-item @(isChildActive ? "expanded" : "")">
                                <div class="menu-parent-label" onclick="toggleSubmenu(this)">
                                    <span class="menu-icon">@item.Icon</span>
                                    <span class="menu-text">@item.Name</span>
                                    <i class="fas fa-chevron-right menu-arrow" style="margin-left: auto; font-size: 0.75rem; transition: transform 0.2s; @(isChildActive ? "transform: rotate(90deg);" : "")"></i>
                                </div>
                                <ul class="submenu-list" style="@(isChildActive ? "display: flex;" : "display: none;")">
                                    @foreach (var sub in item.SubMenus)
                                    {
                                        var isSubActive = HttpContextAccessor.HttpContext?.Request.Path.Value?.StartsWith(sub.Url) == true;
                                        <li class="submenu-item">
                                            <a href="@sub.Url" class="submenu-link @(isSubActive ? "active" : "")">
                                                <span class="submenu-icon">@sub.Icon</span>
                                                <span class="submenu-text">@sub.Name</span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="menu-item">
                                <a href="@item.Url" class="menu-link @(isActive ? "active" : "")">
                                    <span class="menu-icon">@item.Icon</span>
                                    <span class="menu-text">@item.Name</span>
                                </a>
                            </li>
                        }
                    }
                </ul>
            </nav>

            <div class="sidebar-footer">
                <a href="/Clothes/Index?handler=Logout" class="btn-logout">
                    <span>➔</span> <span class="logout-text">Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Mobile sidebar overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

        <!-- Main Dashboard Workspace -->
        <div class="main-wrapper">
            <header class="topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
                    <h2 class="page-title">@ViewData["Title"]</h2>
                </div>
                <div style="display:flex; align-items:center; gap:16px;">
                    <a href="/Orders/CustomerDisplay" target="_blank" class="btn-primary" style="padding: 8px 14px; font-size: 0.85rem; text-decoration: none; border-radius: 8px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); color:#ffffff; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.15);">
                        🖥️ Màn hình phụ khách
                    </a>
                    <div class="system-date">
                        📅 Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </header>

            <main class="content-panel">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Render clean body without sidebar (e.g., Login view) -->
        <div class="main-wrapper no-sidebar">
            <main>
                @RenderBody()
            </main>
        </div>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Apply persisted state on DOM load to prevent flashes
        document.addEventListener('DOMContentLoaded', function() {
            var isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
            var sidebar = document.querySelector('.sidebar');
            var wrapper = document.querySelector('.main-wrapper');
            var icon = document.querySelector('#toggleSidebarDesktopBtn i');

            // Remove initial class
            document.documentElement.classList.remove('sidebar-collapsed-init');

            if (isCollapsed && window.innerWidth > 768) {
                if (sidebar) sidebar.classList.add('collapsed');
                if (wrapper) wrapper.classList.add('collapsed');
                if (icon) icon.className = 'fas fa-chevron-right';
            }
        });

        function toggleSidebar() {
            document.querySelector('.sidebar')?.classList.toggle('open');
            document.getElementById('sidebarOverlay')?.classList.toggle('active');
        }

        function toggleSidebarDesktop() {
            const sidebar = document.querySelector('.sidebar');
            const wrapper = document.querySelector('.main-wrapper');
            const icon = document.querySelector('#toggleSidebarDesktopBtn i');
            
            if (!sidebar) return;

            const isCollapsed = sidebar.classList.toggle('collapsed');
            if (wrapper) wrapper.classList.toggle('collapsed', isCollapsed);
            localStorage.setItem('sidebar-collapsed', isCollapsed);
            
            if (isCollapsed) {
                if (icon) icon.className = 'fas fa-chevron-right';
                // Close all submenus when collapsed
                document.querySelectorAll('.menu-item.expanded').forEach(item => {
                    item.classList.remove('expanded');
                    const sub = item.querySelector('.submenu-list');
                    const arrow = item.querySelector('.menu-arrow');
                    if (sub) sub.style.display = 'none';
                    if (arrow) arrow.style.transform = 'rotate(0deg)';
                });
            } else {
                if (icon) icon.className = 'fas fa-chevron-left';
                // Restore active submenu if any
                document.querySelectorAll('.menu-item').forEach(item => {
                    const hasActiveSub = item.querySelector('.submenu-link.active');
                    if (hasActiveSub) {
                        item.classList.add('expanded');
                        const sub = item.querySelector('.submenu-list');
                        const arrow = item.querySelector('.menu-arrow');
                        if (sub) sub.style.display = 'flex';
                        if (arrow) arrow.style.transform = 'rotate(90deg)';
                    }
                });
            }
        }

        function toggleSubmenu(labelEl) {
            const sidebar = document.querySelector('.sidebar');
            // If sidebar is collapsed, clicking expanding parent toggles sidebar open first
            if (sidebar && sidebar.classList.contains('collapsed')) {
                toggleSidebarDesktop();
                return;
            }
            
            const menuItem = labelEl.closest('.menu-item');
            if (!menuItem) return;

            const arrow = menuItem.querySelector('.menu-arrow');
            const submenu = menuItem.querySelector('.submenu-list');
            
            const isExpanded = menuItem.classList.toggle('expanded');
            if (isExpanded) {
                if (submenu) submenu.style.display = 'flex';
                if (arrow) arrow.style.transform = 'rotate(90deg)';
            } else {
                if (submenu) submenu.style.display = 'none';
                if (arrow) arrow.style.transform = 'rotate(0deg)';
            }
        }
    </script>
</body>
</html>
