@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@inject ClothingRentalUI.Data.ClothingRentalDbContext DbContext
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var fullName = HttpContextAccessor.HttpContext?.Session.GetString("FullName") ?? "Nhân viên";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role") ?? "Staff";

    List<ClothingRentalUI.Data.Entities.Menu> userMenus = new();

    if (!string.IsNullOrEmpty(username))
    {
        // 1. Lấy thông tin user cùng quyền
        var user = DbContext.Users
            .Include(u => u.UserPermissions)
            .FirstOrDefault(u => u.Username.ToLower() == username.ToLower());

        if (user != null)
        {
            var permissionIds = user.UserPermissions.Select(up => up.PermissionId).ToList();

            // 2. Lọc menu theo quyền truy cập
            userMenus = DbContext.Menus
                .Where(m => m.RequiredPermissionId == null || permissionIds.Contains(m.RequiredPermissionId.Value))
                .OrderBy(m => m.DisplayOrder)
                .ToList();
        }
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống Quản lý Cửa hàng</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --primary-grad: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            --sidebar-bg: #1e1b4b; /* Indigo tối */
            --content-bg: #f8fafc; /* Slate sáng */
            --text-light: #ffffff;
            --text-muted: rgba(255, 255, 255, 0.6);
            --transition-speed: 0.3s;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--content-bg);
            color: #0f172a;
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Sidebar Container */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            color: var(--text-light);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            transition: all var(--transition-speed) ease;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* Sidebar Header */
        .sidebar-brand {
            padding: 24px;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #c084fc 0%, #e879f9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* User Profile Area */
        .user-profile {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: var(--primary-grad);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.2rem;
        }

        .profile-info {
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .profile-name {
            font-weight: 600;
            font-size: 0.95rem;
            white-space: nowrap;
            text-overflow: ellipsis;
            overflow: hidden;
        }

        .profile-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Navigation List */
        .sidebar-menu {
            list-style: none;
            padding: 20px 12px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            width: 100%;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .menu-link:hover {
            color: var(--text-light);
            background: rgba(255, 255, 255, 0.06);
            transform: translateX(4px);
        }

        .menu-link.active {
            color: var(--text-light);
            background: var(--primary-grad);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
        }

        .menu-icon {
            font-size: 1.1rem;
        }

        /* Logout Section */
        .sidebar-footer {
            padding: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .btn-logout {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px;
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            border: 1px solid rgba(239, 68, 68, 0.15);
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            border-color: #ef4444;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
        }

        /* Main Workspace Container */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            flex-grow: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top Header Bar */
        .topbar {
            height: 70px;
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 32px;
        }

        .page-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
        }

        .system-date {
            font-size: 0.88rem;
            color: #64748b;
            font-weight: 500;
        }

        /* Page Content Panel */
        .content-panel {
            padding: 32px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        /* Styles for clean views without sidebar (e.g. login page) */
        .no-sidebar {
            margin-left: 0;
            width: 100%;
        }
    </style>
</head>
<body>

    @if (!string.IsNullOrEmpty(username))
    {
        <!-- Left Dynamic Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                CLOTHING RENTAL
            </div>

            <div class="user-profile">
                <div class="profile-avatar">
                    👤
                </div>
                <div class="profile-info">
                    <span class="profile-name">@fullName</span>
                    <span class="profile-role">@role</span>
                </div>
            </div>

            <nav style="flex-grow: 1; display: flex; flex-direction: column;">
                <ul class="sidebar-menu">
                    @foreach (var item in userMenus)
                    {
                        var isActive = HttpContextAccessor.HttpContext?.Request.Path.Value?.StartsWith(item.Url) == true;
                        <li class="menu-item">
                            <a href="@item.Url" class="menu-link @(isActive ? "active" : "")">
                                <span class="menu-icon">@item.Icon</span>
                                <span class="menu-text">@item.Name</span>
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="sidebar-footer">
                <a href="/Clothes/Index?handler=Logout" class="btn-logout">
                    <span>➔</span> Đăng xuất
                </a>
            </div>
        </aside>

        <!-- Main Dashboard Workspace -->
        <div class="main-wrapper">
            <header class="topbar">
                <h2 class="page-title">@ViewData["Title"]</h2>
                <div class="system-date">
                    📅 Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")
                </div>
            </header>

            <main class="content-panel">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Render clean body without sidebar (e.g., Login view) -->
        <div class="main-wrapper no-sidebar">
            <main>
                @RenderBody()
            </main>
        </div>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
