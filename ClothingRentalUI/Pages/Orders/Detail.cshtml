@page
@model ClothingRentalUI.Pages.Orders.DetailModel
@{ ViewData["Title"] = "Chi tiết Đơn hàng"; var o = Model.OrderData; }

<style>
    .data-card { background: #fff; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; margin-bottom: 24px; }
    .card-title { font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
    .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px; margin-bottom: 20px; }
    .info-item label { display: block; font-size: 0.8rem; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .info-item span { font-size: 1rem; font-weight: 600; color: #0f172a; }
    .custom-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    .custom-table th { background: #f8fafc; color: #475569; font-weight: 600; padding: 12px 16px; border-bottom: 1px solid #f1f5f9; text-transform: uppercase; font-size: 0.8rem; }
    .custom-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; color: #334155; vertical-align: middle; }
    .custom-table tbody tr:hover { background: #f8fafc; }
    .status-badge { padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
    .s-draft { background: #f1f5f9; color: #475569; } .s-rented { background: #dbeafe; color: #1e40af; }
    .s-partial { background: #fef08a; color: #854d0e; } .s-closed { background: #dcfce7; color: #166534; }
    .s-overdue { background: #fee2e2; color: #991b1b; }
    .btn-action-lg { padding: 10px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 8px; }
    .btn-confirm { background: #3b82f6; color: #fff; } .btn-confirm:hover { background: #2563eb; }
    .btn-close-order { background: #16a34a; color: #fff; } .btn-close-order:hover { background: #15803d; }
    .btn-return { background: #f59e0b; color: #fff; } .btn-return:hover { background: #d97706; }
    .btn-secondary { background: #f1f5f9; color: #334155; padding: 10px 20px; border-radius: 8px; font-weight: 600; border: 1px solid #e2e8f0; cursor: pointer; text-decoration: none; }
    .txn-type { padding: 3px 8px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
    .txn-in { background: #dcfce7; color: #166534; } .txn-out { background: #fee2e2; color: #991b1b; }
    .return-form { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .return-form input { padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 0.88rem; }
    .form-control-sm { padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.9rem; }
</style>

@if (o == null) { <p>Không tìm thấy đơn hàng.</p> return; }

@{
    var statusClass = o.Status switch { "Draft" => "s-draft", "Rented" => "s-rented", "PartiallyReturned" => "s-partial", "Closed" => "s-closed", "Overdue" => "s-overdue", _ => "s-draft" };
    var statusText = o.Status switch { "Draft" => "Nháp", "Rented" => "Đang thuê", "PartiallyReturned" => "Trả một phần", "Closed" => "Đã đóng", "Overdue" => "Quá hạn", _ => o.Status };
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{ <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:20px;border:1px solid #bbf7d0;">✅ @Model.SuccessMessage</div> }
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{ <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:20px;border:1px solid #fecaca;">❌ @Model.ErrorMessage</div> }

<div class="data-card">
    <div class="card-title">
        <span>📋 Đơn hàng: <span style="color:#1d4ed8;">@o.Code</span></span>
        <span class="status-badge @statusClass">@statusText</span>
    </div>
    <div class="info-grid">
        <div class="info-item"><label>Khách hàng</label><span>@(o.Customer?.FullName ?? "—")</span></div>
        <div class="info-item"><label>Số điện thoại</label><span>📞 @(o.Customer?.PhoneNumber ?? "—")</span></div>
        <div class="info-item"><label>CCCD</label><span>@(o.Customer?.IdentityCard ?? "—")</span></div>
        <div class="info-item"><label>Ngày thuê</label><span>@o.RentDate.AddHours(7).ToString("dd/MM/yyyy")</span></div>
        <div class="info-item"><label>Hạn trả</label><span>@o.DueDate.AddHours(7).ToString("dd/MM/yyyy")</span></div>
        <div class="info-item"><label>Ngày trả thực tế</label><span>@(o.ActualReturnDate.HasValue ? o.ActualReturnDate.Value.AddHours(7).ToString("dd/MM/yyyy HH:mm") : "—")</span></div>
        <div class="info-item"><label>Tổng tiền thuê</label><span style="color:#16a34a;">@o.TotalPrice.ToString("N0")₫</span></div>
        <div class="info-item"><label>Tổng cọc</label><span>@o.TotalDeposit.ToString("N0")₫</span></div>
        <div class="info-item"><label>Phí phát sinh</label><span style="color:#dc2626;">@o.TotalPenalty.ToString("N0")₫</span></div>
        <div class="info-item"><label>Thanh toán cuối</label><span style="font-weight:800;font-size:1.1rem;color:#0f172a;">@o.FinalAmount.ToString("N0")₫</span></div>
        <div class="info-item"><label>Nhân viên tạo</label><span>@(o.CreatedByUser?.FullName ?? "—")</span></div>
        <div class="info-item"><label>Trạng thái cọc</label><span>@(o.DepositStatus == "Holding" ? "Đang giữ" : o.DepositStatus == "Refunded" ? "Đã hoàn" : o.DepositStatus == "Charged" ? "Đã cấn trừ" : "Chưa thu")</span></div>
    </div>
    @if (!string.IsNullOrEmpty(o.Notes))
    { <div style="background:#f8fafc;padding:12px;border-radius:8px;font-size:0.9rem;color:#64748b;margin-top:8px;">📝 @o.Notes</div> }
</div>

<!-- Action Buttons -->
<div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
    <a href="/Orders/Index" class="btn-secondary">← Quay lại</a>
    @if (o.Status == "Draft" && (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_CONFIRM")))
    {
        <form method="post" asp-page-handler="Confirm" asp-route-id="@o.Id" id="confirmOrderForm" style="display:inline-flex;gap:8px;align-items:center;" onsubmit="return onConfirmOrderSubmit();">
            <select name="paymentMethod" id="paymentMethodSelect" class="form-control-sm" onchange="handlePaymentMethodChange()">
                <option value="CASH">💵 Tiền mặt</option>
                <option value="TRANSFER">🏦 Chuyển khoản</option>
            </select>
            <button type="submit" class="btn-action-lg btn-confirm">✅ Xác nhận đơn</button>
        </form>
        <button type="button" class="btn-action-lg btn-return" id="btnPushQR" style="display:none;" onclick="sendQRToDisplay()">
            🖥️ Hiện QR lên màn phụ
        </button>
    }
    @if ((o.Status == "Rented" || o.Status == "PartiallyReturned") && (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_CLOSE")))
    {
        <form method="post" asp-page-handler="Close" asp-route-id="@o.Id" style="display:inline;" onsubmit="return confirm('Đóng đơn hàng? Tất cả sản phẩm chưa trả sẽ được đánh dấu đã trả và hoàn cọc.');">
            <button type="submit" class="btn-action-lg btn-close-order">🔒 Đóng đơn</button>
        </form>
    }
</div>

<!-- Products Table -->
<div class="data-card">
    <h3 class="card-title" style="font-size:1.1rem;">🛍️ Danh sách Sản phẩm</h3>
    <table class="custom-table">
        <thead><tr><th>Mã SP</th><th>Tên</th><th>Giá thuê/ngày</th><th>Số ngày</th><th>Cọc</th><th>Thành tiền</th><th>Phí phát sinh</th><th>Trạng thái</th>
            @if ((o.Status == "Rented" || o.Status == "PartiallyReturned") && (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_RETURN")))
            { <th>Thao tác</th> }
        </tr></thead>
        <tbody>
            @foreach (var d in o.OrderDetails)
            {
                <tr>
                    <td><span style="font-weight:700;color:#1d4ed8;background:#eff6ff;padding:4px 8px;border-radius:6px;font-family:monospace;">@(d.Product?.Code ?? "—")</span></td>
                    <td style="font-weight:600;">@(d.Product?.Name ?? "—")</td>
                    <td>@d.RentPrice.ToString("N0")₫</td>
                    <td>@d.RentDays</td>
                    <td>@d.Deposit.ToString("N0")₫</td>
                    <td style="font-weight:700;">@((d.RentPrice * d.RentDays).ToString("N0"))₫</td>
                    <td style="color:#dc2626;font-weight:600;">@(d.PenaltyFee > 0 ? d.PenaltyFee.ToString("N0") + "₫" : "—")</td>
                    <td>
                        @if (d.IsReturned)
                        { <span class="status-badge s-closed">Đã trả</span> }
                        else
                        { <span class="status-badge s-rented">Đang thuê</span> }
                    </td>
                    @if ((o.Status == "Rented" || o.Status == "PartiallyReturned") && (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_RETURN")))
                    {
                        <td>
                            @if (!d.IsReturned)
                            {
                                <form method="post" asp-page-handler="ReturnItem" asp-route-id="@o.Id" class="return-form" onsubmit="return confirm('Xác nhận trả sản phẩm này?');">
                                    <input type="hidden" name="detailId" value="@d.Id" />
                                    <input type="number" name="penaltyFee" value="0" min="0" step="1000" style="width:100px;" placeholder="Phí phát sinh" />
                                    <input type="text" name="penaltyReason" style="width:140px;" placeholder="Lý do phát sinh..." />
                                    <button type="submit" class="btn-action-lg btn-return" style="padding:6px 12px;font-size:0.85rem;">Trả</button>
                                </form>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Transaction History -->
<div class="data-card">
    <h3 class="card-title" style="font-size:1.1rem;">💳 Lịch sử Giao dịch</h3>
    @if (Model.Transactions.Any())
    {
        <table class="custom-table">
            <thead><tr><th>Thời gian</th><th>Loại</th><th>Phương thức</th><th>Số tiền</th><th>Nhân viên</th><th>Ghi chú</th></tr></thead>
            <tbody>
                @foreach (var t in Model.Transactions)
                {
                    var typeText = t.Type switch { "DEPOSIT_RECEIVED" => "Nhận cọc", "DEPOSIT_REFUNDED" => "Hoàn cọc", "RENTAL_PAYMENT" => "Thu tiền thuê", "PENALTY_PAYMENT" => "Thu phí phát sinh", _ => t.Type };
                    var isIn = t.Type == "DEPOSIT_RECEIVED" || t.Type == "RENTAL_PAYMENT" || t.Type == "PENALTY_PAYMENT";
                    <tr>
                        <td style="font-size:0.88rem;">@t.TransactionDate.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="txn-type @(isIn ? "txn-in" : "txn-out")">@typeText</span></td>
                        <td>@(t.PaymentMethod == "CASH" ? "💵 Tiền mặt" : "🏦 CK")</td>
                        <td style="font-weight:700;color:@(isIn ? "#16a34a" : "#dc2626");">@(isIn ? "+" : "-")@t.Amount.ToString("N0")₫</td>
                        <td>@t.PerformedBy</td>
                        <td style="font-size:0.88rem;color:#64748b;">@(t.Notes ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="text-align:center;color:#64748b;padding:20px;">Chưa có giao dịch nào.</p>
    }
</div>

<script>
    function handlePaymentMethodChange() {
        const select = document.getElementById('paymentMethodSelect');
        const btn = document.getElementById('btnPushQR');
        if (select && select.value === 'TRANSFER') {
            if (btn) btn.style.display = 'inline-block';
            sendQRToDisplay();
        } else {
            if (btn) btn.style.display = 'none';
            sendResetToDisplay(true);
        }
    }

    function sendQRToDisplay() {
        const channel = new BroadcastChannel('vietqr_payment_display');
        const data = {
            amount: @((long)(o.TotalPrice + o.TotalDeposit)),
            orderCode: '@o.Code',
            customerName: @Html.Raw(Json.Serialize(o.Customer?.FullName ?? "Quý khách")),
            items: [
                @foreach (var d in o.OrderDetails)
                {
                    <text>{ name: @Html.Raw(Json.Serialize(d.Product.Name)), size: '@d.Product.Size', color: '@d.Product.Color', qty: 1, rentDays: @d.RentDays, pricePerDay: @((long)d.RentPrice), totalPrice: @((long)(d.RentPrice * d.RentDays)) },</text>
                }
            ],
            days: @(o.OrderDetails.FirstOrDefault()?.RentDays ?? 1),
            totalRent: @((long)o.TotalPrice),
            totalDeposit: @((long)o.TotalDeposit),
            timestamp: Date.now()
        };
        channel.postMessage(data);
        localStorage.setItem('vietqr_payment_data', JSON.stringify(data));
    }

    function sendResetToDisplay(isCancel) {
        const channel = new BroadcastChannel('vietqr_payment_display');
        const data = {
            isCancel: isCancel,
            isReset: !isCancel,
            timestamp: Date.now()
        };
        channel.postMessage(data);
        localStorage.setItem('vietqr_payment_data', JSON.stringify(data));
    }

    function onConfirmOrderSubmit() {
        sendResetToDisplay(false);
        return confirm('Xác nhận đơn hàng? Sẽ thu cọc và tiền thuê.');
    }
</script>

@if (TempData["OrderCompletedSpeech"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const channel = new BroadcastChannel('vietqr_payment_display');
            const data = {
                type: 'payment_success',
                timestamp: Date.now()
            };
            channel.postMessage(data);
            localStorage.setItem('vietqr_payment_data', JSON.stringify(data));
        });
    </script>
}
