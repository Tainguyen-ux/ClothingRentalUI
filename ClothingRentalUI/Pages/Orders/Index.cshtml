@page
@model ClothingRentalUI.Pages.Orders.IndexModel
@{ ViewData["Title"] = "Danh sách Đơn thuê"; }

<style>
    .data-card { background: #fff; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; margin-bottom: 30px; }
    .card-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
    .card-title-group h2 { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .card-title-group p { font-size: 0.88rem; color: #64748b; }
    .filter-container { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; background: #f8fafc; padding: 16px; border-radius: 12px; border: 1px solid #e2e8f0; }
    .form-control { padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; }
    .form-control:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .btn-search { background-color: #0f172a; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; }
    .btn-primary { background-color: #3b82f6; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
    .btn-primary:hover { background-color: #2563eb; }
    .table-responsive { overflow-x: auto; border-radius: 12px; border: 1px solid #f1f5f9; }
    .custom-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    .custom-table th { background-color: #f8fafc; color: #475569; font-weight: 600; padding: 16px 20px; border-bottom: 1px solid #f1f5f9; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.5px; }
    .custom-table td { padding: 16px 20px; border-bottom: 1px solid #f1f5f9; color: #334155; vertical-align: middle; }
    .custom-table tbody tr:hover { background-color: #f8fafc; }
    .status-badge { padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
    .s-draft { background: #f1f5f9; color: #475569; } .s-reserved { background: #f3e8ff; color: #6b21a8; } .s-rented { background: #dbeafe; color: #1e40af; }
    .s-partial { background: #fef08a; color: #854d0e; } .s-closed { background: #dcfce7; color: #166534; }
    .s-overdue { background: #fee2e2; color: #991b1b; }
    .btn-action { background: none; border: none; cursor: pointer; font-size: 1.1rem; color: #64748b; padding: 6px; border-radius: 6px; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .btn-action:hover { background: #f1f5f9; color: #3b82f6; }
    .pagination-container { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; }
    .pagination-info { font-size: 0.9rem; color: #64748b; }
    .pagination-controls { display: flex; gap: 8px; }
    .btn-page { padding: 8px 12px; border: 1px solid #e2e8f0; background: white; border-radius: 6px; color: #334155; text-decoration: none; font-size: 0.9rem; }
    .btn-page.active { background: #3b82f6; color: white; border-color: #3b82f6; }
    .btn-page.disabled { opacity: 0.5; cursor: not-allowed; }

    /* Style cho modal lightbox */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.6);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
    }
    .modal-overlay.active {
        display: flex;
    }
    .modal-content {
        background: white;
        border-radius: 16px;
        width: 100%;
        max-width: 600px;
        padding: 24px;
        position: relative;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        max-height: 90vh;
        overflow-y: auto;
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .modal-header h3 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0f172a;
    }
    .btn-close {
        background: none;
        border: none;
        font-size: 1.25rem;
        color: #64748b;
        cursor: pointer;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.2s;
    }
    .btn-close:hover {
        background: #f1f5f9;
        color: #0f172a;
    }
    /* Carousel Dot indicators styling */
    .carousel-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }
    .carousel-dot.active {
        background: #3b82f6;
        transform: scale(1.3);
        box-shadow: 0 0 8px rgba(59, 130, 246, 0.8);
    }
</style>

<div class="data-card">
    <div class="card-header-flex">
        <div class="card-title-group">
            <h2>Danh sách Đơn thuê</h2>
            <p>Quản lý đơn hàng cho thuê trang phục</p>
        </div>
        @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_CREATE"))
        {
            <a href="/Orders/Create" class="btn-primary"><i class="fas fa-plus"></i> Tạo đơn thuê mới</a>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    { <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:20px;border:1px solid #bbf7d0;">✅ @Model.SuccessMessage</div> }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    { <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:20px;border:1px solid #fecaca;">❌ @Model.ErrorMessage</div> }

    <form method="get" class="filter-container" style="align-items: center;">
        <!-- Barcode Scanning Input -->
        <div style="position: relative; display: flex; align-items: center; margin-right: 8px;">
            <span style="position: absolute; left: 12px; color: #8b5cf6; font-size: 1rem;"><i class="fas fa-barcode"></i></span>
            <input type="text" id="barcodeScanInput" class="form-control" placeholder="Quét Barcode đơn hàng..." style="padding-left: 36px; min-width: 220px; border-color: #c084fc; background-color: #faf5ff; font-weight: 500;" autofocus />
        </div>
        <div style="width: 1px; height: 30px; background-color: #cbd5e1; margin-right: 8px;"></div>

        <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Tìm theo Mã đơn / Tên khách..." style="min-width:250px;flex:1;" />
        <select name="StatusFilter" class="form-control" style="min-width:180px;">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Draft" selected="@(Model.StatusFilter == "Draft")">Nháp</option>
            <option value="Reserved" selected="@(Model.StatusFilter == "Reserved")">Đặt giữ chỗ</option>
            <option value="Rented" selected="@(Model.StatusFilter == "Rented")">Đang thuê</option>
            <option value="PartiallyReturned" selected="@(Model.StatusFilter == "PartiallyReturned")">Trả một phần</option>
            <option value="Closed" selected="@(Model.StatusFilter == "Closed")">Đã đóng</option>
            <option value="Overdue" selected="@(Model.StatusFilter == "Overdue")">Quá hạn</option>
        </select>
        <div style="display: flex; align-items: center; gap: 8px;">
            <label style="font-weight: 600; font-size: 0.85rem; color: #475569; white-space: nowrap;">Từ ngày:</label>
            <input type="date" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="form-control" style="width:140px;" />
        </div>
        <div style="display: flex; align-items: center; gap: 8px;">
            <label style="font-weight: 600; font-size: 0.85rem; color: #475569; white-space: nowrap;">Đến ngày:</label>
            <input type="date" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="form-control" style="width:140px;" />
        </div>
        <button type="submit" class="btn-search"><i class="fas fa-search"></i> Lọc</button>
        <button type="submit" name="handler" value="ExportExcel" class="btn-search" style="background: #16a34a;"><i class="fas fa-file-excel"></i> Xuất Excel</button>
        <a href="/Orders/Index" class="btn-page" style="display:flex;align-items:center;">Xóa lọc</a>
    </form>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width:50px;">STT</th>
                    <th>Mã đơn</th>
                    <th style="width:80px;">Ảnh đơn</th>
                    <th>Khách hàng</th>
                    <th>Ngày thuê</th>
                    <th>Hạn trả</th>
                    <th>Tiền thuê</th>
                    <th>Tiền cọc</th>
                    <th>Giảm giá</th>
                    <th>Tổng</th>
                    <th>Trạng thái</th>
                    <th style="text-align:right;width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Orders.Any())
                {
                    int idx = (Model.PageIndex - 1) * IndexModel.PageSize + 1;
                    foreach (var o in Model.Orders)
                    {
                        var statusClass = o.Status switch { "Draft" => "s-draft", "Reserved" => "s-reserved", "Rented" => "s-rented", "PartiallyReturned" => "s-partial", "Closed" => "s-closed", "Overdue" => "s-overdue", _ => "s-draft" };
                        var statusText = o.Status switch { "Draft" => "Nháp", "Reserved" => "Đặt giữ chỗ", "Rented" => "Đang thuê", "PartiallyReturned" => "Trả một phần", "Closed" => "Đã đóng", "Overdue" => "Quá hạn", _ => o.Status };
                        <tr>
                            <td style="text-align:center;color:#64748b;">@(idx++)</td>
                            <td>
                                <span style="font-weight:700;color:#1d4ed8;background:#eff6ff;padding:4px 8px;border-radius:6px;font-family:monospace;">@o.Code</span>
                                @if (o.IsIdCardReceived)
                                {
                                    <div style="font-size:0.72rem;color:#16a34a;margin-top:4px;font-weight:600;"><i class="fas fa-id-card"></i> Giữ CCCD</div>
                                }
                                else
                                {
                                    <div style="font-size:0.72rem;color:#ea580c;margin-top:4px;font-weight:600;"><i class="fas fa-money-bill-wave"></i> Cọc tiền</div>
                                }
                            </td>
                            <td>
                                @{
                                    string orderFirstImage = "";
                                    int orderImageCount = 0;
                                    var orderImageUrl = o.AttachmentUrl;
                                    if (!string.IsNullOrEmpty(orderImageUrl))
                                    {
                                        if (orderImageUrl.Trim().StartsWith("[") && orderImageUrl.Trim().EndsWith("]"))
                                        {
                                            try
                                            {
                                                var list = System.Text.Json.JsonSerializer.Deserialize<List<string>>(orderImageUrl);
                                                if (list != null && list.Count > 0)
                                                {
                                                    orderImageCount = list.Count;
                                                    orderFirstImage = list[0];
                                                }
                                            }
                                            catch {}
                                        }
                                        else
                                        {
                                            orderImageCount = 1;
                                            orderFirstImage = orderImageUrl;
                                        }
                                    }
                                    var base64OrderImageUrl = string.IsNullOrEmpty(orderImageUrl) ? "" : Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(orderImageUrl));
                                }
                                @if (orderImageCount > 0)
                                {
                                    <div style="position: relative; display: inline-block;">
                                        <div style="cursor: zoom-in;" onclick="openLightbox('@base64OrderImageUrl', 0, event)" title="Click để xem ảnh to">
                                            <img src="@orderFirstImage" style="width: 50px; height: 65px; object-fit: cover; border-radius: 6px; border: 1px solid #cbd5e1; display: block;" />
                                            @if (orderImageCount > 1)
                                            {
                                                <span style="position: absolute; bottom: -4px; right: -4px; background: #3b82f6; color: white; border-radius: 10px; padding: 1px 6px; font-size: 0.7rem; font-weight: 700; border: 1.5px solid white; box-shadow: 0 1px 2px rgba(0,0,0,0.15); z-index: 2;">+@(orderImageCount - 1)</span>
                                            }
                                        </div>
                                        <button type="button" onclick="openOrderImageUploadModalBase64(@o.Id, '@o.Code', '@base64OrderImageUrl')" style="position: absolute; top: -4px; right: -4px; background: #0f172a; color: white; border: 1.5px solid white; border-radius: 50%; width: 18px; height: 18px; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 1px 2px rgba(0,0,0,0.15); z-index: 3;" title="Quản lý ảnh đơn">
                                            <i class="fas fa-pencil-alt" style="font-size:0.55rem;"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div style="width: 50px; height: 65px; background: #f8fafc; border-radius: 6px; border: 1px dashed #cbd5e1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: #94a3b8;" onclick="openOrderImageUploadModalBase64(@o.Id, '@o.Code', '')" title="Đính kèm ảnh đơn">
                                        <i class="fas fa-camera"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div style="font-weight:600;color:#0f172a;">@(o.Customer?.FullName ?? "—")</div>
                                <div style="font-size:0.8rem;color:#64748b;">📞 @(o.Customer?.PhoneNumber ?? "—")</div>
                            </td>
                            <td style="font-size:0.88rem;">@o.RentDate.AddHours(7).ToString("dd/MM/yyyy")</td>
                            <td style="font-size:0.88rem;">@o.DueDate.AddHours(7).ToString("dd/MM/yyyy")</td>
                            <td>@o.TotalPrice.ToString("N0")₫</td>
                            <td>@o.TotalDeposit.ToString("N0")₫</td>
                            <td style="color:#dc2626;">@(o.DiscountAmount > 0 ? $"-{o.DiscountAmount.ToString("N0")}₫" : "0₫")</td>
                            <td style="font-weight:700;color:#0f172a;">@((o.TotalPrice - o.DiscountAmount + o.TotalDeposit + o.TotalPenalty).ToString("N0"))₫</td>
                            <td><span class="status-badge @statusClass">@statusText</span></td>
                            <td style="text-align:right;white-space:nowrap;">
                                <button type="button" class="btn-action" onclick="printOrder(@o.Id, 'invoice')" title="In Hóa đơn" style="color: #166534;"><i class="fas fa-print"></i></button>
                                <button type="button" class="btn-action" onclick="printOrder(@o.Id, 'rental')" title="In Phiếu thuê" style="color: #0369a1;"><i class="fas fa-file-invoice"></i></button>
                                @if (Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_DETAIL"))
                                {
                                    <a href="/Orders/Detail?id=@o.Id" class="btn-action" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                }
                                @if ((Model.IsAdmin || Model.CurrentUserPermissions.Contains("ORDER_DELETE")) && o.Status == "Draft")
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@o.Id" style="display:inline;" onsubmit="return confirm('Xóa đơn hàng nháp này?');">
                                        <button type="submit" class="btn-action" title="Xóa" style="color:#dc2626;"><i class="fas fa-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                        idx++;
                    }
                }
                else
                {
                    <tr><td colspan="11" style="text-align:center;padding:40px;color:#64748b;"><p>Không tìm thấy đơn hàng nào.</p></td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">Trang @Model.PageIndex / @Model.TotalPages (Tổng @Model.TotalItems)</div>
            <div class="pagination-controls">
                @if (Model.PageIndex > 1) { <a href="?pageIndex=@(Model.PageIndex-1)&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page">Trước</a> } else { <span class="btn-page disabled">Trước</span> }
                @for (int i = 1; i <= Model.TotalPages; i++) { if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.PageIndex) <= 2) { <a href="?pageIndex=@i&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page @(i == Model.PageIndex ? "active" : "")">@i</a> } else if (i == 2 || i == Model.TotalPages - 1) { <span style="padding:8px;">...</span> } }
                @if (Model.PageIndex < Model.TotalPages) { <a href="?pageIndex=@(Model.PageIndex+1)&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&FromDate=@(Model.FromDate?.ToString("yyyy-MM-dd"))&ToDate=@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="btn-page">Sau</a> } else { <span class="btn-page disabled">Sau</span> }
            </div>
        </div>
    }
</div>

<!-- Modal Tải ảnh đính kèm đơn hàng -->
<div id="orderImageUploadModal" class="modal-overlay" style="z-index: 9999;">
    <div class="modal-content" style="max-width: 450px;">
        <div class="modal-header">
            <h3 id="orderImageUploadModalTitle">Quản lý ảnh đính kèm đơn</h3>
            <button class="btn-close" onclick="closeOrderImageUploadModal()">✕</button>
        </div>
        
        <!-- Danh sách ảnh hiện có -->
        <div style="margin-bottom: 20px; text-align: left;">
            <p style="font-size: 0.9rem; color: #334155; margin-bottom: 8px; font-weight: 600;">Ảnh đính kèm hiện tại:</p>
            <div id="orderModalImageList" style="display: flex; gap: 8px; flex-wrap: wrap; max-height: 240px; overflow-y: auto; padding: 8px; border: 1px solid #cbd5e1; border-radius: 8px; background: #f8fafc; min-height: 80px;">
                <!-- Populate items via JavaScript -->
            </div>
        </div>

        <!-- Khung xem trước ảnh mới chọn chuẩn bị tải lên -->
        <div id="newOrderImagePreviewContainer" style="display: none; text-align: center; margin-bottom: 20px; background: #eff6ff; padding: 12px; border-radius: 8px; border: 1px dashed #3b82f6;">
            <p style="font-size: 0.85rem; color: #1e40af; margin-bottom: 8px; font-weight: 600;">Ảnh mới chuẩn bị tải lên:</p>
            <div id="newOrderUploadPreviewsList" style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; max-height: 200px; overflow-y: auto; padding: 4px;">
                <!-- Previews will go here -->
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px;">
            <label class="btn-primary" style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; cursor: pointer; border-radius: 8px; font-weight: 600; background: #2563eb; color: white; margin: 0;">
                <i class="fas fa-images"></i> Thư viện
                <input type="file" id="mobileOrderImageInput" accept="image/*" style="display: none;" multiple onchange="previewMobileOrderImage(event)" />
            </label>
            <label class="btn-primary" style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; cursor: pointer; border-radius: 8px; font-weight: 600; background: #059669; color: white; margin: 0;">
                <i class="fas fa-camera"></i> Máy ảnh
                <input type="file" id="mobileOrderCameraInput" accept="image/*" capture="environment" style="display: none;" onchange="previewMobileOrderImage(event)" />
            </label>
        </div>

        <div id="orderUploadProgressContainer" style="display: none; margin-bottom: 20px; background: #eff6ff; padding: 12px; border-radius: 8px; border: 1px solid #bfdbfe; font-size: 0.9rem; color: #1e40af; text-align: center;">
            <i class="fas fa-spinner fa-spin" style="margin-right: 6px;"></i>
            <span id="orderUploadProgressText">Đang tải lên...</span>
        </div>

        <div id="orderUploadErrorMsg" style="display: none; margin-bottom: 20px; background: #fef2f2; padding: 12px; border-radius: 8px; border: 1px solid #fecaca; font-size: 0.9rem; color: #b91c1c; text-align: center;"></div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn-page" onclick="closeOrderImageUploadModal()" style="margin: 0; padding: 10px 16px;">Hủy</button>
            <button id="btnSubmitOrderUpload" class="btn-primary" onclick="startMobileOrderUpload()" style="margin: 0; padding: 10px 16px;" disabled>Tải lên</button>
        </div>
    </div>
</div>

<!-- Lightbox Modal phóng to ảnh (có carousel chuyển ảnh) -->
<div id="imageLightbox" class="modal-overlay" style="z-index: 99999; background: rgba(15, 23, 42, 0.95); cursor: zoom-out;" onclick="closeLightbox()">
    <button class="btn-close" style="position: absolute; top: 24px; right: 24px; color: white; font-size: 2.2rem; background: none; border: none; cursor: pointer; text-shadow: 0 2px 4px rgba(0,0,0,0.5); z-index: 100001;" onclick="closeLightbox()">✕</button>
    
    <!-- Nút Trước -->
    <button id="lightboxPrev" onclick="event.stopPropagation(); navigateLightbox(-1);" style="position: absolute; left: 24px; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.1); border: none; width: 50px; height: 50px; border-radius: 50%; color: white; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; z-index: 100000; outline: none;">
        <i class="fas fa-chevron-left"></i>
    </button>
    
    <!-- Khung hiển thị ảnh -->
    <div style="position: relative; max-width: 90%; max-height: 80vh; display: flex; justify-content: center; align-items: center;" onclick="event.stopPropagation();">
        <img id="lightboxImg" src="" style="max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: 8px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.55); border: 2px solid rgba(255,255,255,0.1); transition: transform 0.25s ease;" />
    </div>

    <!-- Nút Sau -->
    <button id="lightboxNext" onclick="event.stopPropagation(); navigateLightbox(1);" style="position: absolute; right: 24px; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.1); border: none; width: 50px; height: 50px; border-radius: 50%; color: white; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; z-index: 100000; outline: none;">
        <i class="fas fa-chevron-right"></i>
    </button>
    
    <!-- Dấu chấm chỉ số ảnh -->
    <div id="lightboxDots" style="position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 100000;">
        <!-- Dots rendered via JavaScript -->
    </div>
</div>

<script>
    // ========== LIGHTBOX CAROUSEL ==========
    let lightboxImages = [];
    let currentLightboxIndex = 0;

    function openLightbox(imagesInput, initialIndex, event) {
        if (event) event.stopPropagation();
        
        let resolvedInput = imagesInput;
        if (typeof imagesInput === 'string' && imagesInput.trim() !== '') {
            let trimmed = imagesInput.trim();
            if (!trimmed.includes(' ') && !trimmed.includes('\n')) {
                try {
                    const decoded = atob(trimmed);
                    if ((decoded.startsWith('[') && decoded.endsWith(']')) ||
                        decoded.startsWith('/') ||
                        decoded.startsWith('http') ||
                        decoded.includes('.') ||
                        decoded.startsWith('data:image')) {
                        resolvedInput = decoded;
                    }
                } catch (e) {
                    // Not valid base64
                }
            }
        }
        
        if (Array.isArray(resolvedInput)) {
            lightboxImages = resolvedInput;
        } else if (typeof resolvedInput === 'string') {
            try {
                if (resolvedInput.startsWith('[') && resolvedInput.endsWith(']')) {
                    lightboxImages = JSON.parse(resolvedInput);
                } else {
                    lightboxImages = [resolvedInput];
                }
            } catch (e) {
                lightboxImages = [resolvedInput];
            }
        } else {
            lightboxImages = [];
        }
        
        currentLightboxIndex = initialIndex || 0;
        updateLightboxUI();
        
        const lightbox = document.getElementById('imageLightbox');
        if (lightbox) {
            lightbox.classList.add('active');
        }
    }

    function updateLightboxUI() {
        const img = document.getElementById('lightboxImg');
        const prevBtn = document.getElementById('lightboxPrev');
        const nextBtn = document.getElementById('lightboxNext');
        const dotsContainer = document.getElementById('lightboxDots');
        
        if (lightboxImages.length === 0) return;
        
        if (currentLightboxIndex < 0) currentLightboxIndex = lightboxImages.length - 1;
        if (currentLightboxIndex >= lightboxImages.length) currentLightboxIndex = 0;
        
        const currentUrl = lightboxImages[currentLightboxIndex];
        img.src = currentUrl;
        
        if (lightboxImages.length > 1) {
            prevBtn.style.display = 'flex';
            nextBtn.style.display = 'flex';
            dotsContainer.style.display = 'flex';
            
            dotsContainer.innerHTML = lightboxImages.map((_, idx) => `
                <span class="lightbox-dot ${idx === currentLightboxIndex ? 'active' : ''}" onclick="event.stopPropagation(); setLightboxImage(${idx})"></span>
            `).join('');
        } else {
            prevBtn.style.display = 'none';
            nextBtn.style.display = 'none';
            dotsContainer.style.display = 'none';
        }
    }

    function setLightboxImage(index) {
        currentLightboxIndex = index;
        updateLightboxUI();
    }

    function navigateLightbox(direction) {
        currentLightboxIndex += direction;
        updateLightboxUI();
    }

    function closeLightbox() {
        document.getElementById('imageLightbox').classList.remove('active');
    }

    // Keydown controls for lightbox
    document.addEventListener('keydown', function(event) {
        const lightbox = document.getElementById('imageLightbox');
        if (lightbox && lightbox.classList.contains('active')) {
            if (event.key === 'ArrowLeft') {
                navigateLightbox(-1);
            } else if (event.key === 'ArrowRight') {
                navigateLightbox(1);
            } else if (event.key === 'Escape') {
                closeLightbox();
            }
        }
    });

    // ========== ORDER IMAGE UPLOAD MODAL ==========
    let currentUploadOrderId = 0;
    let currentImagesList = [];
    let pendingFiles = [];

    function openOrderImageUploadModal(orderId, orderCode, currentImagesJson) {
        currentUploadOrderId = orderId;
        document.getElementById('orderImageUploadModalTitle').textContent = `Quản lý ảnh đơn hàng ${orderCode}`;
        
        if (currentImagesJson) {
            try {
                if (currentImagesJson.startsWith('[') && currentImagesJson.endsWith(']')) {
                    currentImagesList = JSON.parse(currentImagesJson);
                } else {
                    currentImagesList = [currentImagesJson];
                }
            } catch (e) {
                currentImagesList = currentImagesJson ? [currentImagesJson] : [];
            }
        } else {
            currentImagesList = [];
        }

        renderModalImages();
        
        // Reset inputs & states
        document.getElementById('mobileOrderImageInput').value = '';
        if (document.getElementById('mobileOrderCameraInput')) {
            document.getElementById('mobileOrderCameraInput').value = '';
        }
        pendingFiles = [];
        document.getElementById('newOrderImagePreviewContainer').style.display = 'none';
        document.getElementById('newOrderUploadPreviewsList').innerHTML = '';
        document.getElementById('btnSubmitOrderUpload').disabled = true;
        document.getElementById('orderUploadProgressContainer').style.display = 'none';
        document.getElementById('orderUploadErrorMsg').style.display = 'none';

        document.getElementById('orderImageUploadModal').classList.add('active');
    }

    // Helper for safe passing: base64 decoder
    function openOrderImageUploadModalBase64(orderId, orderCode, base64Url) {
        let jsonStr = '';
        if (base64Url) {
            try {
                jsonStr = atob(base64Url);
            } catch(e) {}
        }
        openOrderImageUploadModal(orderId, orderCode, jsonStr);
    }

    function closeOrderImageUploadModal() {
        document.getElementById('orderImageUploadModal').classList.remove('active');
    }

    function renderModalImages() {
        const container = document.getElementById('orderModalImageList');
        container.innerHTML = '';
        
        if (currentImagesList.length === 0) {
            container.innerHTML = '<p style="color:#94a3b8; font-size:0.85rem; width:100%; text-align:center; padding:10px 0;">Chưa có ảnh nào được đính kèm.</p>';
            return;
        }

        currentImagesList.forEach((url, index) => {
            const wrap = document.createElement('div');
            wrap.style.position = 'relative';
            wrap.style.width = '70px';
            wrap.style.height = '70px';
            wrap.style.borderRadius = '6px';
            wrap.style.overflow = 'hidden';
            wrap.style.border = '1px solid #cbd5e1';
            wrap.style.cursor = 'pointer';

            const img = document.createElement('img');
            img.src = url;
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'cover';
            img.onclick = () => {
                const base64List = btoa(JSON.stringify(currentImagesList));
                openLightbox(base64List, index);
            };

            const delBtn = document.createElement('button');
            delBtn.innerHTML = '✕';
            delBtn.style.position = 'absolute';
            delBtn.style.top = '2px';
            delBtn.style.right = '2px';
            delBtn.style.background = 'rgba(239,68,68,0.9)';
            delBtn.style.color = 'white';
            delBtn.style.border = 'none';
            delBtn.style.borderRadius = '50%';
            delBtn.style.width = '18px';
            delBtn.style.height = '18px';
            delBtn.style.fontSize = '10px';
            delBtn.style.cursor = 'pointer';
            delBtn.onclick = (e) => {
                e.stopPropagation();
                if (confirm('Xóa ảnh này khỏi đơn hàng?')) {
                    currentImagesList.splice(index, 1);
                    renderModalImages();
                    saveOrderImages();
                }
            };

            wrap.appendChild(img);
            wrap.appendChild(delBtn);
            container.appendChild(wrap);
        });
    }

    function previewMobileOrderImage(event) {
        const files = event.target.files;
        if (!files || files.length === 0) return;

        const container = document.getElementById('newOrderImagePreviewContainer');
        const list = document.getElementById('newOrderUploadPreviewsList');
        
        container.style.display = 'block';
        
        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            pendingFiles.push(file);

            const reader = new FileReader();
            reader.onload = function(e) {
                const wrap = document.createElement('div');
                wrap.style.position = 'relative';
                wrap.style.width = '60px';
                wrap.style.height = '60px';
                wrap.style.borderRadius = '6px';
                wrap.style.overflow = 'hidden';
                wrap.style.border = '1px solid #93c5fd';

                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.width = '100%';
                img.style.height = '100%';
                img.style.objectFit = 'cover';

                const delBtn = document.createElement('button');
                delBtn.innerHTML = '✕';
                delBtn.style.position = 'absolute';
                delBtn.style.top = '1px';
                delBtn.style.right = '1px';
                delBtn.style.background = 'rgba(239,68,68,0.9)';
                delBtn.style.color = 'white';
                delBtn.style.border = 'none';
                delBtn.style.borderRadius = '50%';
                delBtn.style.width = '16px';
                delBtn.style.height = '16px';
                delBtn.style.fontSize = '9px';
                delBtn.style.cursor = 'pointer';
                delBtn.onclick = function() {
                    const idx = pendingFiles.indexOf(file);
                    if (idx > -1) {
                        pendingFiles.splice(idx, 1);
                    }
                    wrap.remove();
                    if (pendingFiles.length === 0) {
                        container.style.display = 'none';
                        document.getElementById('btnSubmitOrderUpload').disabled = true;
                    }
                };

                wrap.appendChild(img);
                wrap.appendChild(delBtn);
                list.appendChild(wrap);
            }
            reader.readAsDataURL(file);
        }

        document.getElementById('btnSubmitOrderUpload').disabled = false;
    }

    async function startMobileOrderUpload() {
        if (pendingFiles.length === 0) return;

        const progressContainer = document.getElementById('orderUploadProgressContainer');
        const progressText = document.getElementById('orderUploadProgressText');
        const errorMsg = document.getElementById('orderUploadErrorMsg');
        const btnSubmit = document.getElementById('btnSubmitOrderUpload');

        progressContainer.style.display = 'block';
        errorMsg.style.display = 'none';
        btnSubmit.disabled = true;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        let uploadedCount = 0;

        for (let i = 0; i < pendingFiles.length; i++) {
            const file = pendingFiles[i];
            progressText.textContent = `Đang tải lên (${i + 1}/${pendingFiles.length})...`;

            const formData = new FormData();
            formData.append('file', file);

            try {
                const res = await fetch('?handler=UploadLocalImage', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    currentImagesList.push(data.url);
                    uploadedCount++;
                } else {
                    console.error('File upload failed:', data.error);
                }
            } catch (err) {
                console.error(err);
            }
        }

        progressContainer.style.display = 'none';
        
        if (uploadedCount === 0) {
            errorMsg.textContent = 'Lỗi: Không tải lên được hình ảnh nào. Vui lòng kiểm tra lại.';
            errorMsg.style.display = 'block';
            btnSubmit.disabled = false;
            return;
        }

        // Clean up pending previews
        pendingFiles = [];
        document.getElementById('newOrderImagePreviewContainer').style.display = 'none';
        document.getElementById('newOrderUploadPreviewsList').innerHTML = '';
        document.getElementById('mobileOrderImageInput').value = '';
        if (document.getElementById('mobileOrderCameraInput')) {
            document.getElementById('mobileOrderCameraInput').value = '';
        }

        // Save order changes
        renderModalImages();
        await saveOrderImages();
    }

    async function saveOrderImages() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const urlValue = currentImagesList.length > 0 ? JSON.stringify(currentImagesList) : '';

        try {
            const res = await fetch('?handler=UpdateAttachmentAjax', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({
                    orderId: currentUploadOrderId,
                    url: urlValue
                })
            });
            const data = await res.json();
            if (!data.success) {
                alert('Lỗi cập nhật danh sách ảnh: ' + data.message);
            } else {
                window.location.reload();
            }
        } catch (err) {
            console.error(err);
            alert('Có lỗi xảy ra khi đồng bộ danh sách ảnh.');
        }
    }

    // ========== BARCODE SCANNER AND SEARCH FUNCTIONALITY ==========
    document.getElementById('barcodeScanInput')?.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault(); // Intercept form submission
            
            const barcodeVal = this.value.trim();
            if (!barcodeVal) return;
            
            findOrderByBarcode(barcodeVal);
        }
    });

    function findOrderByBarcode(code) {
        const input = document.getElementById('barcodeScanInput');
        if (!input) return;

        input.disabled = true;
        input.style.opacity = '0.6';
        
        fetch(`?handler=FindOrderByCode&code=${encodeURIComponent(code)}`)
            .then(res => res.json())
            .then(data => {
                input.disabled = false;
                input.style.opacity = '1';
                if (data.success) {
                    // Redirect to details page
                    window.location.href = `/Orders/Detail?id=${data.id}`;
                } else {
                    // Show error toast
                    showBarcodeErrorToast(data.message || 'Không tìm thấy đơn hàng tương ứng.');
                    input.value = '';
                    input.focus();
                }
            })
            .catch(err => {
                input.disabled = false;
                input.style.opacity = '1';
                showBarcodeErrorToast('Đã xảy ra lỗi kết nối khi tìm kiếm đơn hàng.');
                input.value = '';
                input.focus();
            });
    }

    function showBarcodeErrorToast(message) {
        // Create toast element
        const toast = document.createElement('div');
        toast.style.position = 'fixed';
        toast.style.bottom = '24px';
        toast.style.right = '24px';
        toast.style.background = '#ef4444';
        toast.style.color = '#ffffff';
        toast.style.padding = '16px 24px';
        toast.style.borderRadius = '12px';
        toast.style.boxShadow = '0 10px 15px -3px rgba(239, 68, 68, 0.4), 0 4px 6px -4px rgba(239, 68, 68, 0.4)';
        toast.style.zIndex = '999999';
        toast.style.display = 'flex';
        toast.style.alignItems = 'center';
        toast.style.gap = '12px';
        toast.style.fontWeight = '600';
        toast.style.fontSize = '0.95rem';
        toast.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
        toast.style.transform = 'translateY(100px)';
        toast.style.opacity = '0';
        
        toast.innerHTML = `<span style="font-size: 1.2rem;">❌</span> <span>${message}</span>`;
        
        document.body.appendChild(toast);
        
        // Trigger show animation
        setTimeout(() => {
            toast.style.transform = 'translateY(0)';
            toast.style.opacity = '1';
        }, 10);
        
        // Dismiss after 4 seconds
        setTimeout(() => {
            toast.style.transform = 'translateY(100px)';
            toast.style.opacity = '0';
            setTimeout(() => {
                toast.remove();
            }, 300);
        }, 4000);
    }

    function printOrder(orderId, type) {
        const url = `/Orders/Detail?id=${orderId}&handler=Print&type=${type}`;
        const w = window.open(url, '_blank', 'width=800,height=600,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=yes');
        if (w) w.focus();
    }
</script>
