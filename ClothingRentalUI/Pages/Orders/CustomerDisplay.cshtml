@page "/Orders/CustomerDisplay"
@model ClothingRentalUI.Pages.Orders.CustomerDisplayModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Màn hình hiển thị Khách hàng - Clothing Rental</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2563eb;
            --primary-grad: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
            --accent: #10b981;
            --dark: #0f172a;
            --light: #f8fafc;
            --card-bg: rgba(255, 255, 255, 0.9);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f1f5f9;
            color: var(--dark);
            height: 100vh;
            display: flex;
            overflow: hidden;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        /* Screen state: Welcome (Waiting) */
        .screen-state {
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: absolute;
            background: #ffffff;
            border-radius: 24px;
            padding: 40px 30px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
            border: 1px solid #e2e8f0;
        }

        .state-hidden {
            opacity: 0;
            transform: scale(0.95);
            pointer-events: none;
        }

        .welcome-logo {
            font-size: 3.5rem;
            animation: pulse 2s infinite ease-in-out;
            margin-bottom: 20px;
        }

        .welcome-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .welcome-subtitle {
            font-size: 0.95rem;
            color: #64748b;
            line-height: 1.5;
        }

        .clock-container {
            margin-top: 30px;
            background: #f8fafc;
            padding: 10px 20px;
            border-radius: 9999px;
            border: 1px solid #e2e8f0;
            font-weight: 600;
            font-size: 0.88rem;
            color: #475569;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        /* Screen state: Payment QR */
        .payment-card {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.06);
            width: 100%;
            max-width: 480px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: absolute;
        }

        .payment-header {
            text-align: center;
            margin-bottom: 16px;
            width: 100%;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 12px;
        }

        .client-welcome {
            font-size: 0.88rem;
            color: var(--primary);
            font-weight: 700;
            margin-bottom: 2px;
        }

        .payment-info-title {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--dark);
        }

        .amount-display {
            font-size: 2rem;
            font-weight: 800;
            color: var(--accent);
            margin: 8px 0 2px 0;
            letter-spacing: -0.5px;
        }

        .amount-label {
            font-size: 0.8rem;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .qr-wrapper {
            background: #f8fafc;
            border: 2px dashed #3b82f6;
            border-radius: 16px;
            padding: 12px;
            margin-bottom: 16px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 220px;
            height: 220px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.01);
        }

        .qr-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 8px;
        }

        .bank-details {
            width: 100%;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 12px;
        }

        .bank-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            font-size: 0.85rem;
        }

        .bank-row:last-child {
            margin-bottom: 0;
        }

        .bank-row label {
            color: #64748b;
            font-weight: 500;
        }

        .bank-row span {
            color: var(--dark);
            font-weight: 600;
            text-align: right;
        }

        .copy-hint {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            color: var(--primary);
            font-weight: 600;
            font-size: 0.8rem;
            background: rgba(37, 99, 235, 0.08);
            padding: 6px 12px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(37, 99, 235, 0.1);
        }

        .copy-hint:hover {
            background: rgba(37, 99, 235, 0.15);
        }

        /* Sound switch */
        .sound-switch {
            position: absolute;
            top: 16px;
            right: 16px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            transition: all 0.2s;
            font-size: 1.1rem;
            z-index: 100;
        }

        .sound-switch:hover {
            background: #f8fafc;
            transform: scale(1.05);
        }

        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.08); }
        }

        /* Loading spinner */
        .qr-spinner {
            position: absolute;
            width: 36px;
            height: 36px;
            border: 3px solid #cbd5e1;
            border-top: 3px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <!-- Sound controls -->
    <button class="sound-switch" id="soundBtn" onclick="toggleSound()" title="Bật/Tắt âm thanh thông báo">🔊</button>

    <div class="container">
        <!-- STATE 1: WELCOME SCREEN -->
        <div class="screen-state" id="welcomeState">
            <div class="welcome-logo">🛍️</div>
            <h2 class="welcome-title">Xin kính chào Quý khách</h2>
            <p class="welcome-subtitle">
                Vui lòng theo dõi chi tiết hóa đơn quét mã chuyển khoản tại đây khi thanh toán.
            </p>
            <div class="clock-container">
                <span>🕒</span> <span id="liveClock">00:00:00</span>
            </div>
        </div>

        <!-- STATE 2: PAYMENT QR SCREEN -->
        <div class="screen-state state-hidden" id="paymentState">
            <div class="payment-card">
                <div class="payment-header">
                    <div class="client-welcome" id="clientGreeting">Chào bạn!</div>
                    <div class="payment-info-title">HÓA ĐƠN THANH TOÁN</div>
                    
                    <div class="amount-display" id="paymentAmount">0₫</div>
                    <div class="amount-label" id="paymentOrderCode">ĐƠN HÀNG</div>
                </div>

                <div class="qr-wrapper" id="qrContainer">
                    <div class="qr-spinner" id="qrSpinner"></div>
                    <img src="" alt="Mã VietQR" class="qr-image" id="qrImg" onload="document.getElementById('qrSpinner').style.display='none'" onerror="this.src='https://placehold.co/220x220/f8fafc/0f172a?text=Loi+Sinh+QR'" />
                </div>

                <div class="bank-details">
                    <div class="bank-row">
                        <label>Tài khoản thụ hưởng</label>
                        <span id="bankAccountNo">00000000</span>
                    </div>
                    <div class="bank-row">
                        <label>Chủ tài khoản</label>
                        <span id="bankAccountName">NGUYEN VAN A</span>
                    </div>
                    <div class="bank-row">
                        <label>Nội dung chuyển khoản</label>
                        <span id="bankDescription" style="color:var(--primary); font-family:monospace; font-size:0.95rem;">HD0001</span>
                    </div>
                </div>

                <div class="copy-hint" id="copyBtn" onclick="copyDescription()">
                    <span>📋</span> Sao chép Nội dung chuyển khoản
                </div>
            </div>
        </div>
    </div>

    <!-- Audio notifier (Standard beep) -->
    <audio id="beepAudio" src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" preload="auto"></audio>

    <script>
        // Default Bank Settings loaded from Model
        const configBankBin = '@Model.BankBin';
        const configAccountNo = '@Model.AccountNumber';
        const configAccountName = '@Model.AccountName';

        let soundEnabled = true;
        let countdownTimer = null;

        // Sound handler
        function toggleSound() {
            soundEnabled = !soundEnabled;
            document.getElementById('soundBtn').textContent = soundEnabled ? '🔊' : '🔇';
        }

        function playBeep() {
            if (soundEnabled) {
                const audio = document.getElementById('beepAudio');
                if (audio) {
                    audio.play().catch(e => console.log("Sound play error: " + e));
                }
            }
        }

        // Live Clock
        function updateClock() {
            const now = new Date();
            const time = now.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            const date = now.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
            document.getElementById('liveClock').textContent = `${time} - ${date}`;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Screen transition
        function showWelcomeScreen() {
            document.getElementById('welcomeState').classList.remove('state-hidden');
            document.getElementById('paymentState').classList.add('state-hidden');
            if (countdownTimer) {
                clearTimeout(countdownTimer);
                countdownTimer = null;
            }
        }

        function showPaymentScreen(data) {
            playBeep();

            // Set customer name greeting
            const greeting = data.customerName ? `Chào bạn, ${data.customerName}!` : 'Cảm ơn Quý khách!';
            document.getElementById('clientGreeting').textContent = greeting;

            // Set amount formatted
            const formattedAmount = Number(data.amount).toLocaleString('vi-VN') + '₫';
            document.getElementById('paymentAmount').textContent = formattedAmount;

            // Set order code labels
            document.getElementById('paymentOrderCode').textContent = `ĐƠN HÀNG: ${data.orderCode}`;
            document.getElementById('bankDescription').textContent = data.orderCode;

            // Resolve bank details
            const bankBin = data.bankBin || configBankBin;
            const accountNo = data.accountNo || configAccountNo;
            const accountName = data.accountName || configAccountName;

            document.getElementById('bankAccountNo').textContent = accountNo;
            document.getElementById('bankAccountName').textContent = accountName;

            // Show spinner and load VietQR Image
            document.getElementById('qrSpinner').style.display = 'block';
            
            // Format URL call to VietQR
            const qrUrl = `https://img.vietqr.io/image/${bankBin}-${accountNo}-qr_only.png?amount=${data.amount}&addInfo=${data.orderCode}&accountName=${encodeURIComponent(accountName)}`;
            document.getElementById('qrImg').src = qrUrl;

            // Transition states
            document.getElementById('welcomeState').classList.add('state-hidden');
            document.getElementById('paymentState').classList.remove('state-hidden');

            // Auto reset back to welcome screen after 5 minutes of inactivity
            if (countdownTimer) clearTimeout(countdownTimer);
            countdownTimer = setTimeout(() => {
                showWelcomeScreen();
            }, 300000); // 5 mins
        }

        // Copy Clipboard helper
        function copyDescription() {
            const descText = document.getElementById('bankDescription').textContent;
            navigator.clipboard.writeText(descText).then(() => {
                const btn = document.getElementById('copyBtn');
                const origHtml = btn.innerHTML;
                btn.innerHTML = '✅ Đã sao chép nội dung!';
                btn.style.background = '#dcfce7';
                btn.style.color = '#166534';
                setTimeout(() => {
                    btn.innerHTML = origHtml;
                    btn.style.background = '';
                    btn.style.color = '';
                }, 2000);
            });
        }

        // BroadcastChannel Listener
        const channel = new BroadcastChannel('vietqr_payment_display');
        channel.onmessage = function(event) {
            const data = event.data;
            if (data) {
                if (data.isCancel || data.isReset) {
                    showWelcomeScreen();
                } else {
                    showPaymentScreen(data);
                }
            }
        };

        // LocalStorage fallback event listener (for cross-browser/same origin support)
        window.addEventListener('storage', function(e) {
            if (e.key === 'vietqr_payment_data' && e.newValue) {
                try {
                    const data = JSON.parse(e.newValue);
                    if (data.isCancel || data.isReset) {
                        showWelcomeScreen();
                    } else {
                        // Avoid trigger twice if timestamp is too old
                        if (Date.now() - data.timestamp < 10000) {
                            showPaymentScreen(data);
                        }
                    }
                } catch(err) {
                    console.error("Localstorage parser error", err);
                }
            }
        });
    </script>
</body>
</html>
