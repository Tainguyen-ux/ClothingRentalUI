@page
@model ClothingRentalUI.Pages.Orders.CreateModel
@{ ViewData["Title"] = "Tạo Đơn hàng mới"; }

<style>
    .data-card { background: #fff; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); padding: 30px; margin-bottom: 24px; }
    .card-title { font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-bottom: 20px; }
    .form-row { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
    .form-group { flex: 1; min-width: 200px; }
    .form-group label { display: block; font-weight: 600; font-size: 0.88rem; color: #334155; margin-bottom: 6px; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; font-family: inherit; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .search-results { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; max-height: 250px; overflow-y: auto; z-index: 100; box-shadow: 0 8px 16px rgba(0,0,0,0.1); display: none; }
    .search-results.active { display: block; }
    .search-item { padding: 10px 14px; cursor: pointer; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; }
    .search-item:hover { background: #f0f9ff; }
    .cart-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    .cart-table th { background: #f8fafc; color: #475569; font-weight: 600; padding: 12px 16px; border-bottom: 1px solid #f1f5f9; text-transform: uppercase; font-size: 0.8rem; }
    .cart-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .btn-remove { background: none; border: none; color: #dc2626; cursor: pointer; font-size: 1rem; }
    .btn-primary { background: #3b82f6; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; font-size: 1rem; }
    .btn-primary:hover { background: #2563eb; }
    .btn-secondary { background: #f1f5f9; color: #334155; padding: 12px 24px; border-radius: 8px; font-weight: 600; border: 1px solid #e2e8f0; cursor: pointer; text-decoration: none; font-size: 1rem; }
    .summary-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.95rem; }
    .summary-row.total { font-weight: 800; font-size: 1.1rem; color: #0f172a; border-top: 2px solid #e2e8f0; padding-top: 12px; margin-top: 8px; }
</style>

<div class="data-card">
    <h2 class="card-title">📋 Tạo Đơn Hàng Mới</h2>
    <div class="form-row">
        <div class="form-group" style="flex:2;">
            <label>Khách hàng *</label>
            <select id="customerId" onchange="updateCustomerInfo()">
                <option value="">-- Chọn khách hàng --</option>
                @foreach (var c in Model.Customers)
                {
                    <option value="@c.Id" data-phone="@c.PhoneNumber" data-idcard="@(c.IdentityCard ?? "")">@c.FullName - @c.PhoneNumber</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Số ngày thuê *</label>
            <input type="number" id="rentDays" value="1" min="1" onchange="recalculate()" />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group"><label>Ghi chú</label><textarea id="orderNotes" rows="2" placeholder="Ghi chú đơn hàng..."></textarea></div>
    </div>
</div>

<div class="data-card">
    <h2 class="card-title">🛍️ Thêm Sản phẩm vào đơn</h2>
    <div style="position:relative;margin-bottom:16px;">
        <input type="text" id="productSearch" class="form-control" placeholder="Tìm kiếm sản phẩm theo Mã hoặc Tên..." style="width:100%;padding:12px 16px;border:1px solid #cbd5e1;border-radius:8px;" oninput="searchProducts(this.value)" />
        <div id="searchResults" class="search-results"></div>
    </div>

    <table class="cart-table">
        <thead><tr><th>Mã SP</th><th>Tên</th><th>Size/Màu</th><th>Giá thuê/ngày</th><th>Tiền cọc</th><th>Thành tiền</th><th></th></tr></thead>
        <tbody id="cartBody"><tr id="emptyRow"><td colspan="7" style="text-align:center;padding:30px;color:#64748b;">Chưa có sản phẩm nào trong đơn.</td></tr></tbody>
    </table>
</div>

<div class="data-card">
    <h2 class="card-title">💰 Tổng kết</h2>
    <div class="summary-row"><span>Tổng tiền thuê:</span><span id="sumRent">0₫</span></div>
    <div class="summary-row"><span>Tổng tiền cọc:</span><span id="sumDeposit">0₫</span></div>
    <div class="summary-row total"><span>Tổng cộng (Thuê + Cọc):</span><span id="sumTotal">0₫</span></div>

    <div style="display:flex;gap:12px;margin-top:24px;justify-content:flex-end;">
        <a href="/Orders/Index" class="btn-secondary">← Quay lại</a>
        <button class="btn-primary" onclick="submitOrder()">✅ Tạo Đơn Hàng</button>
    </div>
</div>

<script>
    let cartItems = [];
    let searchTimeout;

    async function searchProducts(term) {
        clearTimeout(searchTimeout);
        if (term.length < 1) { document.getElementById('searchResults').classList.remove('active'); return; }
        searchTimeout = setTimeout(async () => {
            const res = await fetch(`?handler=SearchProducts&term=${encodeURIComponent(term)}`);
            const data = await res.json();
            const el = document.getElementById('searchResults');
            if (data.success && data.data.length > 0) {
                el.innerHTML = data.data.map(p => `
                    <div class="search-item" onclick="addToCart(${JSON.stringify(p).replace(/"/g, '&quot;')})">
                        <strong>${p.code}</strong> - ${p.name} <span style="color:#64748b;font-size:0.85rem;">(${p.size || ''} ${p.color || ''}) | Giá: ${Number(p.pricePerDay).toLocaleString()}₫/ngày | Cọc: ${Number(p.deposit).toLocaleString()}₫ | Kho: ${p.available}</span>
                    </div>
                `).join('');
                el.classList.add('active');
            } else {
                el.innerHTML = '<div class="search-item" style="color:#64748b;">Không tìm thấy sản phẩm.</div>';
                el.classList.add('active');
            }
        }, 300);
    }

    function addToCart(product) {
        if (cartItems.find(i => i.id === product.id)) { alert('Sản phẩm đã có trong đơn.'); return; }
        cartItems.push(product);
        document.getElementById('searchResults').classList.remove('active');
        document.getElementById('productSearch').value = '';
        renderCart();
    }

    function removeFromCart(productId) {
        cartItems = cartItems.filter(i => i.id !== productId);
        renderCart();
    }

    function renderCart() {
        const body = document.getElementById('cartBody');
        const days = parseInt(document.getElementById('rentDays').value) || 1;
        if (cartItems.length === 0) {
            body.innerHTML = '<tr id="emptyRow"><td colspan="7" style="text-align:center;padding:30px;color:#64748b;">Chưa có sản phẩm nào trong đơn.</td></tr>';
        } else {
            body.innerHTML = cartItems.map(p => `
                <tr>
                    <td><span style="font-weight:700;color:#1d4ed8;background:#eff6ff;padding:4px 8px;border-radius:6px;font-family:monospace;">${p.code}</span></td>
                    <td style="font-weight:600;">${p.name}</td>
                    <td>${p.size || ''} ${p.color || ''}</td>
                    <td>${Number(p.pricePerDay).toLocaleString()}₫</td>
                    <td>${Number(p.deposit).toLocaleString()}₫</td>
                    <td style="font-weight:700;color:#0f172a;">${(p.pricePerDay * days).toLocaleString()}₫</td>
                    <td><button class="btn-remove" onclick="removeFromCart(${p.id})"><i class="fas fa-times-circle"></i></button></td>
                </tr>
            `).join('');
        }
        recalculate();
    }

    function recalculate() {
        const days = parseInt(document.getElementById('rentDays').value) || 1;
        let rent = 0, deposit = 0;
        cartItems.forEach(p => { rent += p.pricePerDay * days; deposit += p.deposit; });
        document.getElementById('sumRent').textContent = rent.toLocaleString() + '₫';
        document.getElementById('sumDeposit').textContent = deposit.toLocaleString() + '₫';
        document.getElementById('sumTotal').textContent = (rent + deposit).toLocaleString() + '₫';
    }

    async function submitOrder() {
        const customerId = parseInt(document.getElementById('customerId').value);
        const rentDays = parseInt(document.getElementById('rentDays').value);
        const notes = document.getElementById('orderNotes').value;
        if (!customerId) { alert('Vui lòng chọn khách hàng.'); return; }
        if (cartItems.length === 0) { alert('Vui lòng thêm ít nhất 1 sản phẩm.'); return; }

        const body = { customerId, rentDays, notes, items: cartItems.map(p => ({ productId: p.id })) };
        const res = await fetch('?handler=CreateOrderAjax', {
            method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.success) {
            alert('Tạo đơn hàng thành công: ' + data.code);
            window.location.href = '/Orders/Detail?id=' + data.orderId;
        } else {
            alert('Lỗi: ' + data.message);
        }
    }

    document.addEventListener('click', e => { if (!e.target.closest('#productSearch') && !e.target.closest('#searchResults')) document.getElementById('searchResults').classList.remove('active'); });
</script>
@Html.AntiForgeryToken()
