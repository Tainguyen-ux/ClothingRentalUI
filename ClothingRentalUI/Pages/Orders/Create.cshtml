    async function uploadOrderImages(event) {
        const files = event.target.files;
        if (!files || files.length === 0) return;

        const indicator = document.getElementById('uploadingIndicator');
        indicator.style.display = 'inline';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        for (let i = 0; i < files.length; i++) {
            const formData = new FormData();
            formData.append('file', files[i]);

            try {
                const res = await fetch('?handler=UploadLocalImage', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    attachedImages.push(data.url);
                } else {
                    alert('Lỗi tải ảnh: ' + (data.error || 'Không rõ lỗi.'));
                }
            } catch (err) {
                console.error(err);
                alert('Có lỗi xảy ra khi tải ảnh lên.');
            }
        }

        indicator.style.display = 'none';
        document.getElementById('orderImageFileInput').value = '';
        document.getElementById('orderImageCameraInput').value = '';
        renderAttachedImages();
    }

    function renderAttachedImages() {
        const container = document.getElementById('orderImageList');
        const noImg = document.getElementById('noAttachedImages');
        
        // Clear previous dynamically created elements
        const dyns = container.querySelectorAll('.dyn-img-wrap');
        dyns.forEach(d => d.remove());

        if (attachedImages.length === 0) {
            noImg.style.display = 'block';
            return;
        }

        noImg.style.display = 'none';

        attachedImages.forEach((url, idx) => {
            const wrap = document.createElement('div');
            wrap.className = 'dyn-img-wrap';
            wrap.style.position = 'relative';
            wrap.style.width = '75px';
            wrap.style.height = '75px';
            wrap.style.borderRadius = '6px';
            wrap.style.overflow = 'hidden';
            wrap.style.border = '1px solid #cbd5e1';

            const img = document.createElement('img');
            img.src = url;
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'cover';

            const delBtn = document.createElement('button');
            delBtn.innerHTML = '✕';
            delBtn.style.position = 'absolute';
            delBtn.style.top = '2px';
            delBtn.style.right = '2px';
            delBtn.style.background = 'rgba(239,68,68,0.9)';
            delBtn.style.color = 'white';
            delBtn.style.border = 'none';
            delBtn.style.borderRadius = '50%';
            delBtn.style.width = '18px';
            delBtn.style.height = '18px';
            delBtn.style.fontSize = '10px';
            delBtn.style.cursor = 'pointer';
            delBtn.onclick = function(e) {
                e.preventDefault();
                attachedImages.splice(idx, 1);
                renderAttachedImages();
            };

            wrap.appendChild(img);
            wrap.appendChild(delBtn);
            container.appendChild(wrap);
        });
    }

    // ========== GIFT REPLACEMENT FUNCTIONS ==========
    let changingGiftProductId = null;
    let changingGiftParentId = null;

    function initiateChangeGift(productId, parentId) {
        changingGiftProductId = productId;
        changingGiftParentId = parentId;

        document.getElementById('giftModalTitle').textContent = '🔄 Thay đổi Quà tặng / Phụ kiện';
        document.getElementById('giftSearchLabel').textContent = 'Tìm sản phẩm thay thế';
        
        // Clear search input and results in the modal
        document.getElementById('giftProductSearch').value = '';
        const resultsEl = document.getElementById('giftProductResults');
        resultsEl.innerHTML = '';
        resultsEl.classList.remove('active');
        resultsEl.style.display = 'none';
        
        // Show modal
        document.getElementById('changeGiftModal').classList.add('active');
        setTimeout(() => document.getElementById('giftProductSearch').focus(), 100);
    }

    function initiateAddAccessory(parentId) {
        changingGiftProductId = null;
        changingGiftParentId = parentId;

        document.getElementById('giftModalTitle').textContent = '➕ Thêm Phụ kiện / Hàng tặng';
        document.getElementById('giftSearchLabel').textContent = 'Tìm phụ kiện đính kèm';
        
        // Clear search input and results in the modal
        document.getElementById('giftProductSearch').value = '';
        const resultsEl = document.getElementById('giftProductResults');
        resultsEl.innerHTML = '';
        resultsEl.classList.remove('active');
        resultsEl.style.display = 'none';
        
        // Show modal
        document.getElementById('changeGiftModal').classList.add('active');
        setTimeout(() => document.getElementById('giftProductSearch').focus(), 100);
    }

    function closeChangeGiftModal() {
        document.getElementById('changeGiftModal').classList.remove('active');
        changingGiftProductId = null;
        changingGiftParentId = null;
    }

    let giftSearchTimeout;
    let giftProductSearchData = [];
    let giftHighlightIdx = -1;

    async function searchGiftProducts(term) {
        clearTimeout(giftSearchTimeout);
        giftHighlightIdx = -1;
        const el = document.getElementById('giftProductResults');
        if (term.length < 1) { 
            el.classList.remove('active'); 
            el.style.display = 'none';
            giftProductSearchData = []; 
            return; 
        }
        giftSearchTimeout = setTimeout(async () => {
            const res = await fetch(`?handler=SearchProducts&term=${encodeURIComponent(term)}`);
            const data = await res.json();
            if (data.success && data.data.length > 0) {
                giftProductSearchData = data.data;
                el.innerHTML = data.data.map((p, i) => `
                    <div class="sr-item" data-index="${i}" onclick="selectReplacementGift(giftProductSearchData[${i}])" onmouseenter="giftHighlightIdx=${i};updateGiftHighlight()">
                        <div class="sr-name">${p.code} — ${p.name}</div>
                        <div class="sr-sub">${p.size || ''} ${p.color || ''} | Kho: ${p.available}</div>
                    </div>
                `).join('');
                el.classList.add('active');
                el.style.display = 'block';
            } else {
                giftProductSearchData = [];
                el.innerHTML = '<div class="sr-item" style="color:#64748b;">Không tìm thấy sản phẩm.</div>';
                el.classList.add('active');
                el.style.display = 'block';
            }
        }, 300);
    }

    function handleGiftSearchKey(e) {
        const resultsEl = document.getElementById('giftProductResults');
        if (!resultsEl.classList.contains('active') || giftProductSearchData.length === 0) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            giftHighlightIdx = Math.min(giftHighlightIdx + 1, giftProductSearchData.length - 1);
            updateGiftHighlight();
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            giftHighlightIdx = Math.max(giftHighlightIdx - 1, 0);
            updateGiftHighlight();
        } else if (e.key === 'Enter') {
            e.preventDefault();
            const idx = giftHighlightIdx;
            if (idx >= 0 && idx < giftProductSearchData.length) {
                selectReplacementGift(giftProductSearchData[idx]);
            }
        } else if (e.key === 'Escape') {
            resultsEl.classList.remove('active');
            resultsEl.style.display = 'none';
            giftHighlightIdx = -1;
        }
    }

    function updateGiftHighlight() {
        const resultsEl = document.getElementById('giftProductResults');
        const items = resultsEl.querySelectorAll('.sr-item');
        items.forEach((el, i) => {
            el.classList.toggle('highlighted', i === giftHighlightIdx);
            if (i === giftHighlightIdx) el.scrollIntoView({ block: 'nearest' });
        });
    }

    function selectReplacementGift(newProduct) {
        if (changingGiftProductId === null && changingGiftParentId !== null) {
            // Add new accessory/gift
            const exists = cartItems.some(i => i.id === newProduct.id && i.isGift && i.parentId === changingGiftParentId);
            if (exists) {
                alert('Sản phẩm này đã được đính kèm làm phụ kiện cho sản phẩm này rồi.');
                return;
            }

            cartItems.push({
                id: newProduct.id,
                code: newProduct.code,
                name: newProduct.name,
                size: newProduct.size,
                color: newProduct.color,
                pricePerDay: 0,
                deposit: 0,
                available: newProduct.available || 999,
                qty: 1,
                rentDays: 1,
                isGift: true,
                parentId: changingGiftParentId
            });

            renderCart();
            closeChangeGiftModal();
            return;
        }

        // Find the index of the gift item being changed in cartItems
        const index = cartItems.findIndex(i => i.id === changingGiftProductId && i.isGift && i.parentId === changingGiftParentId);
        if (index !== -1) {
            // Check if the replacement product already exists in the cart as a gift under the same parent
            const exists = cartItems.some(i => i.id === newProduct.id && i.isGift && i.parentId === changingGiftParentId && i.id !== changingGiftProductId);
            if (exists) {
                alert('Sản phẩm này đã tồn tại trong danh sách quà tặng của sản phẩm cha.');
                return;
            }

            // Update the cart item properties
            cartItems[index].id = newProduct.id;
            cartItems[index].code = newProduct.code;
            cartItems[index].name = newProduct.name;
            cartItems[index].size = newProduct.size;
            cartItems[index].color = newProduct.color;
            cartItems[index].available = newProduct.available || 999;
            // Note: pricePerDay and deposit remain 0 because it's a gift
            cartItems[index].pricePerDay = 0;
            cartItems[index].deposit = 0;
            
            // Re-render
            renderCart();
            closeChangeGiftModal();
        } else {
            alert('Không tìm thấy quà tặng cần thay thế trong giỏ hàng.');
        }
    }

    // Bind outside clicks to close the gift product search dropdown
    document.addEventListener('click', e => {
        if (!e.target.closest('#giftProductSearch') && !e.target.closest('#giftProductResults')) {
            const el = document.getElementById('giftProductResults');
            if (el) {
                el.classList.remove('active');
                el.style.display = 'none';
            }
            giftHighlightIdx = -1;
        }
    });

    function toggleIdCardInput() {
        const isChecked = document.getElementById('isIdCardReceived').checked;
        const group = document.getElementById('receivedIdCardGroup');
        if (isChecked && customerMode === 'existing') {
            group.style.display = '';
            if (!document.getElementById('receivedIdCard').value) {
                document.getElementById('receivedIdCard').value = selectedCustomerIdCard;
            }
        } else {
            group.style.display = 'none';
        }
    }

    // Initialize state
    toggleIdCardInput();
</script>
